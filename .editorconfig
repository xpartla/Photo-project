root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

[*.{js,ts,tsx,jsx,mjs,cjs}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{astro,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.sln]
indent_style = tab

[Dockerfile*]
indent_size = 4
