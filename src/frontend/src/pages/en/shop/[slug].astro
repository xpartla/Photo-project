---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import { getProduct } from "../../../lib/api";
import { t, getAlternateUrl } from "../../../lib/i18n";
import { buildSrcset, getFallbackUrl } from "../../../lib/imageUrl";
import type { ShopProduct } from "../../../lib/api";

const lang = "en";
const { slug } = Astro.params;
const pageUrl = Astro.url.pathname;
const alternateUrl = getAlternateUrl(lang, pageUrl);

let product: ShopProduct | null = null;

try {
  product = await getProduct(slug!, lang);
} catch {
  return Astro.redirect(`/${lang}/shop`);
}

if (!product) return Astro.redirect(`/${lang}/shop`);

const variants = (product.productVariants || []).filter((v) => v.isAvailable);
const defaultVariant = variants[0] ?? product.productVariants?.[0];
const isSoldOut = !product.isAvailable || variants.length === 0;

const editionText = product.editionSize
  ? `${t(lang, "shop.edition")} ${product.editionSold} ${t(lang, "shop.editionOf")} ${product.editionSize} — ${product.editionRemaining} ${t(lang, "shop.remaining")}`
  : t(lang, "shop.openEdition");

// Unique format and paper options for the selectors.
const formats = Array.from(new Map(variants.map((v) => [v.formatCode, { code: v.formatCode, name: v.formatName }])).values());
const papers = Array.from(new Map(variants.map((v) => [v.paperTypeCode, { code: v.paperTypeCode, name: v.paperTypeName }])).values());

const pageTitle = `${product.title} — ${t(lang, "shop.title")} — PartlPhoto`;
const apiBase = import.meta.env.PUBLIC_CLIENT_API_URL || "http://localhost:5000";
---

<BaseLayout title={pageTitle} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={product.description || t(lang, "shop.description")}
    lang={lang}
    path={pageUrl}
  />
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Product",
      "name": product.title,
      "description": product.description,
      "image": product.variants.length > 0 ? getFallbackUrl(product.variants) : undefined,
      "offers": {
        "@type": "Offer",
        "price": defaultVariant?.price ?? product.minPrice ?? 0,
        "priceCurrency": product.currency,
        "availability": product.isAvailable
          ? "https://schema.org/InStock"
          : "https://schema.org/SoldOut",
        "seller": { "@type": "Organization", "name": "PartlPhoto" }
      }
    })} />
  </Fragment>

  <div class="product-detail-page">
    <div class="product-detail-page__decor product-detail-page__decor--1"></div>
    <div class="product-detail-page__decor product-detail-page__decor--2"></div>
    <div class="product-detail-page__decor product-detail-page__decor--3"></div>

    <div class="product-detail">
      <div class="product-detail__frame">
        <div class="product-detail__mat">
          <div class="product-detail__image">
            {product.variants.length > 0 ? (
              <picture>
                <source srcset={buildSrcset(product.variants, "webp")} type="image/webp" />
                <img src={getFallbackUrl(product.variants)} alt={product.title} loading="eager" />
              </picture>
            ) : (
              <div style="height:400px;background:#eee;display:flex;align-items:center;justify-content:center;">
                <span>No image</span>
              </div>
            )}
          </div>
          {product.editionSize ? (
            <span class={`product-detail__stamp product-detail__stamp--limited ${isSoldOut ? "product-detail__stamp--sold-out" : ""}`}>
              {isSoldOut ? t(lang, "shop.soldOut") : `${product.editionRemaining}/${product.editionSize}`}
            </span>
          ) : (
            <span class="product-detail__stamp">{t(lang, "shop.openEdition")}</span>
          )}
        </div>
      </div>

      <div class="product-detail__info">
        <a href={`/${lang}/shop`} class="product-detail__back product-detail__reveal">
          &larr; {t(lang, "shop.backToShop")}
        </a>

        <h1 class="product-detail__title product-detail__reveal">{product.title}</h1>

        <hr class="product-detail__divider product-detail__reveal" />

        {product.description && (
          <p class="product-detail__description product-detail__reveal">{product.description}</p>
        )}

        {product.tags?.length > 0 && (
          <div class="product-detail__tags product-detail__reveal">
            {product.tags.map((tg) => (
              <a href={`/${lang}/shop?tag=${tg.slug}`} class="product-detail__tag">#{tg.name}</a>
            ))}
          </div>
        )}

        {product.isLimitedEdition && defaultVariant ? (
          <div class="product-detail__meta product-detail__reveal">
            <div class="product-detail__meta-item">
              <strong>{t(lang, "shop.format")}</strong>
              {defaultVariant.formatName}
            </div>
            <div class="product-detail__meta-item">
              <strong>{t(lang, "shop.paperType")}</strong>
              {defaultVariant.paperTypeName}
            </div>
          </div>
        ) : (
          <div class="product-detail__selectors product-detail__reveal">
            <label class="product-detail__selector">
              <span class="product-detail__selector-label">{t(lang, "shop.format")}</span>
              <select id="format-select" class="product-detail__select">
                {formats.map((f) => (
                  <option value={f.code} selected={f.code === defaultVariant?.formatCode}>
                    {f.name}
                  </option>
                ))}
              </select>
            </label>
            <label class="product-detail__selector">
              <span class="product-detail__selector-label">{t(lang, "shop.paperType")}</span>
              <select id="paper-select" class="product-detail__select">
                {papers.map((p) => (
                  <option value={p.code} selected={p.code === defaultVariant?.paperTypeCode}>
                    {p.name}
                  </option>
                ))}
              </select>
            </label>
          </div>
        )}

        <div class={`product-detail__edition product-detail__reveal ${isSoldOut ? "product-detail__edition--sold-out" : ""}`}>
          <span class="product-detail__edition-dot"></span>
          {isSoldOut ? t(lang, "shop.soldOut") : editionText}
        </div>

        <div class="product-detail__price-row product-detail__reveal">
          <span class="product-detail__price" id="product-price">{defaultVariant?.price ?? product.minPrice ?? 0}</span>
          <span class="product-detail__currency">{product.currency}</span>
        </div>

        <div class="product-detail__actions product-detail__reveal">
          <button
            class="product-detail__add-btn"
            id="add-to-cart-btn"
            data-product-id={product.id}
            data-product-slug={product.slug}
            data-product-title={product.title}
            data-product-currency={product.currency}
            data-product-image={product.variants.length > 0 ? getFallbackUrl(product.variants) : ""}
            data-edition-size={product.editionSize ?? ""}
            data-edition-sold={product.editionSold}
            disabled={isSoldOut}
          >
            {isSoldOut ? t(lang, "shop.soldOut") : t(lang, "shop.addToCart")}
          </button>
        </div>
      </div>
    </div>

    <div class="product-quality">
      <div class="product-quality__item">
        <div class="product-quality__icon">&#9733;</div>
        <div class="product-quality__label">Fine Art Print</div>
      </div>
      <div class="product-quality__item">
        <div class="product-quality__icon">&#9883;</div>
        <div class="product-quality__label">Archival Paper</div>
      </div>
      <div class="product-quality__item">
        <div class="product-quality__icon">&#10003;</div>
        <div class="product-quality__label">Certificate of Authenticity</div>
      </div>
      <div class="product-quality__item">
        <div class="product-quality__icon">&#9993;</div>
        <div class="product-quality__label">Safe Delivery</div>
      </div>
    </div>
  </div>

  <script id="product-variants-data" type="application/json" set:html={JSON.stringify(product.productVariants || [])}></script>

  <script>
    import { addToCart } from "../../../lib/cart";

    const dataEl = document.getElementById("product-variants-data");
    const allVariants = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];

    const btn = document.getElementById("add-to-cart-btn") as HTMLButtonElement | null;
    const priceEl = document.getElementById("product-price");
    const formatSel = document.getElementById("format-select") as HTMLSelectElement | null;
    const paperSel = document.getElementById("paper-select") as HTMLSelectElement | null;

    function currentVariant() {
      if (!formatSel || !paperSel) return allVariants[0] ?? null;
      return allVariants.find(
        (v: any) => v.formatCode === formatSel.value && v.paperTypeCode === paperSel.value && v.isAvailable,
      ) ?? null;
    }

    function refresh() {
      const v = currentVariant();
      if (priceEl) priceEl.textContent = v ? String(v.price) : "—";
      if (btn) {
        btn.disabled = !v;
      }
    }

    formatSel?.addEventListener("change", refresh);
    paperSel?.addEventListener("change", refresh);
    refresh();

    if (btn) {
      btn.addEventListener("click", async () => {
        if (btn.disabled) return;
        const v = currentVariant();
        if (!v) return;
        try {
          await addToCart({
            productSlug: btn.dataset.productSlug!,
            productId: btn.dataset.productId,
            variantId: v.id,
            formatCode: v.formatCode,
            formatName: v.formatName,
            paperTypeCode: v.paperTypeCode,
            paperTypeName: v.paperTypeName,
            title: btn.dataset.productTitle!,
            price: v.price,
            currency: btn.dataset.productCurrency || "EUR",
            imageUrl: btn.dataset.productImage || "",
            editionSize: btn.dataset.editionSize ? parseInt(btn.dataset.editionSize) : null,
            editionSold: parseInt(btn.dataset.editionSold || "0"),
          });

          const original = btn.textContent;
          btn.textContent = "✓";
          btn.disabled = true;
          setTimeout(() => { btn.textContent = original; btn.disabled = false; }, 1000);

          window.dispatchEvent(new CustomEvent("cart:changed"));
        } catch (err) {
          console.error("add to cart failed", err);
        }
      });
    }
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../styles/components/shop";
</style>
