---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import ShopFilters from "../../../components/ShopFilters.astro";
import {
  getProducts,
  getShopCollections,
  getShopTags,
  fetchApi,
} from "../../../lib/api";
import { t, getAlternateUrl } from "../../../lib/i18n";
import { buildSrcset, getFallbackUrl } from "../../../lib/imageUrl";
import type {
  ShopProduct,
  ShopCollectionSummary,
  ShopTagSummary,
  ShopFormat,
  ShopPaperType,
} from "../../../lib/api";

const lang = "en";
const pageUrl = Astro.url.pathname;
const alternateUrl = getAlternateUrl(lang, pageUrl);

const params = Astro.url.searchParams;
const active = {
  collection: params.get("collection") ?? undefined,
  tag: params.get("tag") ?? undefined,
  format: params.get("format") ?? undefined,
  paperType: params.get("paperType") ?? undefined,
  q: params.get("q") ?? undefined,
  available: params.get("available") ?? undefined,
};

let products: ShopProduct[] = [];
let total = 0;
let collections: ShopCollectionSummary[] = [];
let tags: ShopTagSummary[] = [];
let formats: ShopFormat[] = [];
let paperTypes: ShopPaperType[] = [];

try {
  const [list, cols, tagList, fmts, papers] = await Promise.all([
    getProducts({ lang, size: 50, ...active }),
    getShopCollections(lang),
    getShopTags(lang),
    fetchApi<ShopFormat[]>("/api/shop/formats"),
    fetchApi<ShopPaperType[]>("/api/shop/paper-types"),
  ]);
  products = list.items;
  total = list.total;
  collections = cols;
  tags = tagList;
  formats = fmts;
  paperTypes = papers;
} catch {
  // fallback
}

const pageTitle = `${t(lang, "shop.title")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={t(lang, "shop.description")}
    lang={lang}
    path={pageUrl}
  />

  <main class="shop">
    <div class="shop__header">
      <h1 class="shop__title">{t(lang, "shop.title")}</h1>
      <p class="shop__subtitle">{t(lang, "shop.subtitle")}</p>
    </div>

    <ShopFilters
      lang={lang}
      action={`/${lang}/shop`}
      active={active}
      collections={collections}
      tags={tags}
      formats={formats}
      paperTypes={paperTypes}
      totalCount={total}
    />

    {products.length === 0 ? (
      <p class="shop__empty">{t(lang, "shop.noProducts")}</p>
    ) : (
      <div class="shop__grid" id="product-grid">
        {products.map((product) => {
          const editionRemaining = product.editionRemaining;
          const isSoldOut = !product.isAvailable;
          const badgeText = isSoldOut
            ? t(lang, "shop.soldOut")
            : product.editionSize
              ? `${editionRemaining} ${t(lang, "shop.remaining")}`
              : t(lang, "shop.openEdition");
          const badgeClass = isSoldOut ? "product-card__badge--sold-out" : "";

          const variants = product.productVariants ?? [];
          const specs = product.isLimitedEdition && variants.length > 0
            ? [variants[0].formatName, variants[0].paperTypeName].filter(Boolean)
            : Array.from(new Set(variants.map((v) => v.formatName))).slice(0, 3);

          return (
            <a href={`/${lang}/shop/${product.slug}`} class="product-card" data-available={product.isAvailable ? "true" : "false"}>
              <div class="product-card__image">
                {product.variants.length > 0 ? (
                  <picture>
                    <source
                      srcset={buildSrcset(product.variants, "webp")}
                      type="image/webp"
                    />
                    <img
                      src={getFallbackUrl(product.variants)}
                      alt={product.title}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                ) : (
                  <div style="height:280px;background:#eee;display:flex;align-items:center;justify-content:center;">
                    <span>No image</span>
                  </div>
                )}
                <span class={`product-card__badge ${badgeClass}`}>
                  {badgeText}
                </span>
              </div>
              <div class="product-card__body">
                <h3 class="product-card__title">{product.title}</h3>
                {specs.length > 0 && (
                  <div class="product-card__specs">
                    {specs.map((s) => (
                      <span class="product-card__spec">{s}</span>
                    ))}
                  </div>
                )}
                {product.tags?.length > 0 && (
                  <div class="product-card__specs product-card__specs--tags">
                    {product.tags.map((tg) => (
                      <span class="product-card__spec product-card__spec--tag">#{tg.name}</span>
                    ))}
                  </div>
                )}
                <div class="product-card__footer">
                  <span class="product-card__price">
                    {!product.isLimitedEdition && product.minPrice !== product.maxPrice && (
                      <span class="product-card__price-prefix">{t(lang, "shop.fromPrice")} </span>
                    )}
                    {product.minPrice ?? 0} {product.currency}
                  </span>
                  <span class="product-card__cta">{t(lang, "shop.viewDetail")}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../styles/components/shop";
</style>
