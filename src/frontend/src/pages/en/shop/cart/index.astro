---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { t, getAlternateUrl } from "../../../../lib/i18n";

const lang = "en";
const pageUrl = Astro.url.pathname;
const alternateUrl = getAlternateUrl(lang, pageUrl);
const pageTitle = `${t(lang, "cart.title")} — PartlPhoto`;
const shopUrl = `/${lang}/shop`;
const checkoutUrl = `/${lang}/shop/checkout`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="cart">
    <h1 class="cart__title">{t(lang, "cart.title")}</h1>

    <div id="cart-content">
      <div class="cart__empty">
        <p class="cart__empty-text">{t(lang, "cart.empty")}</p>
        <a href={shopUrl} class="cart__empty-link">{t(lang, "cart.browseShop")}</a>
      </div>
    </div>
  </main>

  <script id="cart-labels" type="application/json" set:html={JSON.stringify({
    lang,
    shopUrl,
    checkoutUrl,
    empty: t(lang, "cart.empty"),
    browseShop: t(lang, "cart.browseShop"),
    remove: t(lang, "cart.remove"),
    total: t(lang, "cart.total"),
    checkout: t(lang, "cart.checkout"),
  })}></script>

  <script>
    import { getCart, updateQuantity, removeFromCart, type CartLine } from "../../../../lib/cart";

    const labelsEl = document.getElementById("cart-labels");
    const labels = labelsEl ? JSON.parse(labelsEl.textContent || "{}") : {};

    async function renderCart() {
      const container = document.getElementById("cart-content");
      if (!container) return;

      const snapshot = await getCart();
      const cart = snapshot.lines;

      if (cart.length === 0) {
        container.innerHTML = `
          <div class="cart__empty">
            <p class="cart__empty-text">${labels.empty}</p>
            <a href="${labels.shopUrl}" class="cart__empty-link">${labels.browseShop}</a>
          </div>`;
        return;
      }

      const itemsHtml = cart
        .map((item, idx) => {
          const variantSpec = [item.formatName, item.paperTypeName].filter(Boolean).join(" · ");
          const image = item.imageUrl
            ? `<img class="cart-item__image" src="${item.imageUrl}" alt="${escape(item.title)}" />`
            : `<div class="cart-item__image" style="background:#eee"></div>`;
          return `
            <div class="cart-item" data-idx="${idx}">
              ${image}
              <div class="cart-item__info">
                <h3 class="cart-item__title">${escape(item.title)}</h3>
                ${variantSpec ? `<p class="cart-item__spec">${escape(variantSpec)}</p>` : ""}
                <span class="cart-item__price">${item.price} ${item.currency || "EUR"}</span>
              </div>
              <div class="cart-item__quantity">
                <button class="cart-item__qty-btn" data-action="decrease" data-idx="${idx}">-</button>
                <span class="cart-item__qty-value">${item.quantity}</span>
                <button class="cart-item__qty-btn" data-action="increase" data-idx="${idx}">+</button>
              </div>
              <button class="cart-item__remove" data-action="remove" data-idx="${idx}">${labels.remove}</button>
            </div>`;
        })
        .join("");

      container.innerHTML = `
        <div class="cart__items">${itemsHtml}</div>
        <div class="cart__footer">
          <div class="cart__total">
            <span>${labels.total}</span>
            <span>${snapshot.total.toFixed(2)} EUR</span>
          </div>
          <a href="${labels.checkoutUrl}" class="cart__checkout-btn">${labels.checkout}</a>
        </div>`;

      container.querySelectorAll<HTMLButtonElement>("[data-action]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const idx = Number(btn.getAttribute("data-idx"));
          const line = cart[idx];
          if (!line) return;
          const action = btn.getAttribute("data-action");
          if (action === "increase") await updateQuantity(line, line.quantity + 1);
          else if (action === "decrease") await updateQuantity(line, line.quantity - 1);
          else if (action === "remove") await removeFromCart(line);
          window.dispatchEvent(new CustomEvent("cart:changed"));
          renderCart();
        });
      });
    }

    function escape(s: string): string {
      return s.replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c] as string),
      );
    }

    renderCart();
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../styles/components/cart";
</style>
