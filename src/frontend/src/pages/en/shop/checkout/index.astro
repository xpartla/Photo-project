---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { t } from "../../../../lib/i18n";

const lang = "en";
const pageTitle = `${t(lang, "checkout.title")} — PartlPhoto`;
const apiBase = import.meta.env.PUBLIC_CLIENT_API_URL || "http://localhost:5000";
---

<BaseLayout title={pageTitle} lang={lang}>
  <div class="checkout">
    <h1 class="checkout__title">{t(lang, "checkout.title")}</h1>

    <div class="checkout__form" id="checkout-form">
      <h2 class="checkout__section-title">{t(lang, "checkout.shipping")}</h2>

      <div class="checkout__field">
        <label class="checkout__label" for="ship-name">{t(lang, "checkout.name")}</label>
        <input class="checkout__input" id="ship-name" type="text" required />
      </div>
      <div class="checkout__field">
        <label class="checkout__label" for="ship-street">{t(lang, "checkout.street")}</label>
        <input class="checkout__input" id="ship-street" type="text" required />
      </div>
      <div class="checkout__field">
        <label class="checkout__label" for="ship-city">{t(lang, "checkout.city")}</label>
        <input class="checkout__input" id="ship-city" type="text" required />
      </div>
      <div class="checkout__field">
        <label class="checkout__label" for="ship-postal">{t(lang, "checkout.postalCode")}</label>
        <input class="checkout__input" id="ship-postal" type="text" required />
      </div>
      <div class="checkout__field">
        <label class="checkout__label" for="ship-country">{t(lang, "checkout.country")}</label>
        <input class="checkout__input" id="ship-country" type="text" value="SK" />
      </div>

      <label class="checkout__checkbox">
        <input type="checkbox" id="same-billing" checked />
        {t(lang, "checkout.sameAsShipping")}
      </label>

      <div id="billing-fields" style="display:none;">
        <h2 class="checkout__section-title">{t(lang, "checkout.billing")}</h2>
        <div class="checkout__field">
          <label class="checkout__label" for="bill-name">{t(lang, "checkout.name")}</label>
          <input class="checkout__input" id="bill-name" type="text" />
        </div>
        <div class="checkout__field">
          <label class="checkout__label" for="bill-street">{t(lang, "checkout.street")}</label>
          <input class="checkout__input" id="bill-street" type="text" />
        </div>
        <div class="checkout__field">
          <label class="checkout__label" for="bill-city">{t(lang, "checkout.city")}</label>
          <input class="checkout__input" id="bill-city" type="text" />
        </div>
        <div class="checkout__field">
          <label class="checkout__label" for="bill-postal">{t(lang, "checkout.postalCode")}</label>
          <input class="checkout__input" id="bill-postal" type="text" />
        </div>
        <div class="checkout__field">
          <label class="checkout__label" for="bill-country">{t(lang, "checkout.country")}</label>
          <input class="checkout__input" id="bill-country" type="text" />
        </div>
      </div>
    </div>

    <div class="checkout__summary">
      <h3 class="checkout__summary-title">{t(lang, "checkout.orderSummary")}</h3>
      <div id="summary-items"></div>
      <div class="checkout__summary-total">
        <span>{t(lang, "cart.total")}</span>
        <span id="summary-total">0 EUR</span>
      </div>
      <button class="checkout__pay-btn" id="pay-btn">{t(lang, "checkout.payNow")}</button>
      <div id="checkout-error" class="checkout__error" style="text-align:center;margin-top:8px;"></div>
    </div>
  </div>

  <script id="checkout-config" type="application/json" set:html={JSON.stringify({
    apiBase,
    lang,
    loginUrl: `/${lang}/login?return=/${lang}/shop/checkout`,
    returnUrlTemplate: `/${lang}/shop/orders/ORDER_ID`,
    cancelUrl: `/${lang}/shop/cart`,
    processingText: t(lang, "checkout.processing"),
    requiredText: t(lang, "checkout.required"),
    payText: t(lang, "checkout.payNow"),
  })}></script>

  <script>
    import { getCart } from "../../../../lib/cart";

    const cfg = JSON.parse(document.getElementById("checkout-config")!.textContent!);

    // Redirect to login if not authenticated — return-url points back here so
    // the user lands back on checkout after login, with their cart already
    // synced server-side.
    const token = localStorage.getItem("partlphoto_token");
    if (!token) {
      window.location.href = cfg.loginUrl;
      throw new Error("redirect");
    }

    // Always read from the cart service — server cart for authed users.
    // This is the fix: no more stale localStorage reads after login.
    const summaryEl = document.getElementById("summary-items");
    const totalEl = document.getElementById("summary-total");
    const payBtn = document.getElementById("pay-btn") as HTMLButtonElement | null;

    async function renderSummary() {
      const snapshot = await getCart();
      if (snapshot.lines.length === 0) {
        if (summaryEl) summaryEl.innerHTML = "<p>Cart is empty.</p>";
        if (totalEl) totalEl.textContent = "0 EUR";
        if (payBtn) payBtn.disabled = true;
        return;
      }
      if (summaryEl) {
        summaryEl.innerHTML = snapshot.lines
          .map((item) => {
            const pills = [item.formatName, item.paperTypeName]
              .filter(Boolean)
              .map((p) => `<span class="checkout__summary-spec">${escape(p as string)}</span>`)
              .join("");
            const thumb = item.imageUrl
              ? `<img class="checkout__summary-thumb" src="${escape(item.imageUrl)}" alt="${escape(item.title)}" loading="lazy" />`
              : `<div class="checkout__summary-thumb checkout__summary-thumb--placeholder"></div>`;
            return `<div class="checkout__summary-item">
              ${thumb}
              <div class="checkout__summary-info">
                <div class="checkout__summary-item-title">${escape(item.title)} <span class="checkout__summary-qty">&times; ${item.quantity}</span></div>
                ${pills ? `<div class="checkout__summary-specs">${pills}</div>` : ""}
              </div>
              <div class="checkout__summary-item-price">${(item.price * item.quantity).toFixed(2)} EUR</div>
            </div>`;
          })
          .join("");
      }
      if (totalEl) totalEl.textContent = `${snapshot.total.toFixed(2)} EUR`;
      if (payBtn) payBtn.disabled = false;
    }

    function escape(s: string) {
      return s.replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c] as string),
      );
    }

    renderSummary();

    document.getElementById("same-billing")?.addEventListener("change", (e) => {
      const fields = document.getElementById("billing-fields");
      if (fields) fields.style.display = (e.target as HTMLInputElement).checked ? "none" : "";
    });

    payBtn?.addEventListener("click", async () => {
      const errEl = document.getElementById("checkout-error");
      const name = (document.getElementById("ship-name") as HTMLInputElement).value.trim();
      const street = (document.getElementById("ship-street") as HTMLInputElement).value.trim();
      const city = (document.getElementById("ship-city") as HTMLInputElement).value.trim();
      const postal = (document.getElementById("ship-postal") as HTMLInputElement).value.trim();
      const country = (document.getElementById("ship-country") as HTMLInputElement).value.trim();

      if (!name || !street || !city || !postal) {
        if (errEl) errEl.textContent = cfg.requiredText;
        return;
      }

      payBtn.disabled = true;
      payBtn.textContent = cfg.processingText;
      if (errEl) errEl.textContent = "";

      const sameBilling = (document.getElementById("same-billing") as HTMLInputElement).checked;
      const billingAddress = sameBilling ? null : {
        name: (document.getElementById("bill-name") as HTMLInputElement).value.trim() || name,
        street: (document.getElementById("bill-street") as HTMLInputElement).value.trim() || street,
        city: (document.getElementById("bill-city") as HTMLInputElement).value.trim() || city,
        postalCode: (document.getElementById("bill-postal") as HTMLInputElement).value.trim() || postal,
        country: (document.getElementById("bill-country") as HTMLInputElement).value.trim() || country,
      };

      try {
        const res = await fetch(`${cfg.apiBase}/api/shop/orders`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${localStorage.getItem("partlphoto_token")}`,
          },
          body: JSON.stringify({
            shippingAddress: { name, street, city, postalCode: postal, country },
            billingAddress,
            returnUrl: cfg.returnUrlTemplate,
            cancelUrl: cfg.cancelUrl,
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || `Error ${res.status}`);
        }

        const data = await res.json();
        window.dispatchEvent(new CustomEvent("cart:changed"));
        window.location.href = data.redirectUrl;
      } catch (err: any) {
        if (errEl) errEl.textContent = err.message || "Order failed";
        payBtn.disabled = false;
        payBtn.textContent = cfg.payText;
      }
    });
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../styles/components/checkout";
</style>
