---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import BlogPostEditor from "../../../../../components/BlogPostEditor.astro";
import { t } from "../../../../../lib/i18n";

const lang = "en";
const { id } = Astro.params;
const pageTitle = `${t(lang, "admin.blog.editPost")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <BlogPostEditor lang={lang} mode="edit" postId={id} />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../../styles/components/admin";
</style>
