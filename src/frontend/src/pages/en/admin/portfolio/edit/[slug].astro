---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import AdminPhotoEditor from "../../../../../components/AdminPhotoEditor.astro";
import { t } from "../../../../../lib/i18n";

const lang = "en";
const { slug } = Astro.params;
const pageTitle = `${t(lang, "admin.portfolio.editPhoto")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <AdminPhotoEditor lang={lang} slug={slug ?? ""} />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../../styles/components/admin";
  @use "../../../../../styles/components/account";
</style>
