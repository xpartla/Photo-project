---
import BaseLayout from "../../../../../../layouts/BaseLayout.astro";
import AdminCollectionEditor from "../../../../../../components/AdminCollectionEditor.astro";
import { t } from "../../../../../../lib/i18n";

const lang = "en";
const { slug } = Astro.params;
const pageTitle = `${t(lang, "admin.common.edit")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <AdminCollectionEditor lang={lang} mode="edit" slug={slug ?? ""} />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../../../styles/components/admin";
  @use "../../../../../../styles/components/account";
</style>
