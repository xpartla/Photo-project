---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import AdminProductEditor from "../../../../../components/AdminProductEditor.astro";
import { t } from "../../../../../lib/i18n";

const lang = "en";
const pageTitle = `${t(lang, "admin.shop.newProduct")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <AdminProductEditor lang={lang} mode="create" />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../../styles/components/admin";
  @use "../../../../../styles/components/account";
</style>
