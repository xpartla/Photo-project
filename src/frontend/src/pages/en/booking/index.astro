---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import BookingCalendar from "../../../components/BookingCalendar.astro";
import { getSessionTypes, getAvailability } from "../../../lib/api";
import { t } from "../../../lib/i18n";
import type { SessionType, AvailabilitySlot } from "../../../lib/api";

const lang = "en";

let sessionTypes: SessionType[] = [];
let initialSlots: AvailabilitySlot[] = [];
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

try {
  [sessionTypes, initialSlots] = await Promise.all([
    getSessionTypes(lang),
    getAvailability(currentMonth, currentYear),
  ]);
} catch {
  // fallback
}

// Server-side uses Docker-internal URL; client-side JS needs the host-accessible URL
const apiBase = import.meta.env.PUBLIC_CLIENT_API_URL || "http://localhost:5000";

const calendarTranslations: Record<string, string> = {
  "booking.calendar.sessionType": t(lang, "booking.calendar.sessionType"),
  "booking.calendar.prev": t(lang, "booking.calendar.prev"),
  "booking.calendar.next": t(lang, "booking.calendar.next"),
  "booking.calendar.noSlots": t(lang, "booking.calendar.noSlots"),
  "booking.calendar.selectDay": t(lang, "booking.calendar.selectDay"),
  "booking.calendar.availableSlots": t(lang, "booking.calendar.availableSlots"),
  "booking.calendar.slotAvailable": t(lang, "booking.calendar.slotAvailable"),
  "booking.form.title": t(lang, "booking.form.title"),
  "booking.form.name": t(lang, "booking.form.name"),
  "booking.form.email": t(lang, "booking.form.email"),
  "booking.form.phone": t(lang, "booking.form.phone"),
  "booking.form.dogCount": t(lang, "booking.form.dogCount"),
  "booking.form.specialRequests": t(lang, "booking.form.specialRequests"),
  "booking.form.specialRequestsPlaceholder": t(lang, "booking.form.specialRequestsPlaceholder"),
  "booking.form.submit": t(lang, "booking.form.submit"),
  "booking.form.submitting": t(lang, "booking.form.submitting"),
  "booking.form.required": t(lang, "booking.form.required"),
  "booking.form.invalidEmail": t(lang, "booking.form.invalidEmail"),
};

const pageTitle = `${t(lang, "booking.title")} — PartlPhoto`;
const pageDescription = t(lang, "booking.description");

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "PartlPhoto",
    description: pageDescription,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bratislava",
      addressCountry: "SK",
    },
    priceRange: "€€",
  },
  ...sessionTypes.map((st) => ({
    "@context": "https://schema.org",
    "@type": "Service",
    name: st.name,
    description: st.description,
    provider: { "@type": "LocalBusiness", name: "PartlPhoto" },
    offers: {
      "@type": "Offer",
      price: st.basePrice,
      priceCurrency: st.currency,
    },
  })),
];

const categoryKeys: Record<string, string> = {
  portrait: "booking.category.portrait",
  action: "booking.category.action",
  studio: "booking.category.studio",
  outdoor: "booking.category.outdoor",
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path="/en/booking"
    jsonLd={jsonLd}
  />

  <div class="booking-hero">
    <h1 class="booking-hero__title">{t(lang, "booking.title")}</h1>
    <p class="booking-hero__subtitle">{t(lang, "booking.subtitle")}</p>
  </div>

  <div class="session-grid reveal-stagger">
    {sessionTypes.map((st) => (
      <div class="session-card reveal">
        {st.category && (
          <span class="session-card__category">
            {t(lang, categoryKeys[st.category] || `booking.category.${st.category}`)}
          </span>
        )}
        <h2 class="session-card__name">{st.name}</h2>
        <p class="session-card__description">{st.description}</p>
        <div class="session-card__meta">
          <span class="session-card__meta-item">
            {t(lang, "booking.duration")}: {st.durationMinutes} {t(lang, "booking.minutes")}
          </span>
          <span class="session-card__meta-item">
            {t(lang, "booking.maxDogs")}: {st.maxDogs}
          </span>
        </div>
        <div class="session-card__price">
          {st.basePrice} {st.currency}
        </div>
        {st.includes && st.includes.length > 0 && (
          <ul class="session-card__includes">
            {st.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
        <button type="button" class="session-card__cta" data-open-modal={st.slug}>
          {t(lang, "booking.selectSession")}
        </button>
      </div>
    ))}
  </div>

  <!-- Session detail modals -->
  {sessionTypes.map((st) => (
    <div class="session-modal-overlay" id={`modal-${st.slug}`} data-modal>
      <div class="session-modal" role="dialog" aria-labelledby={`modal-title-${st.slug}`}>
        <button type="button" class="session-modal__close" data-close-modal aria-label={t(lang, "portfolio.close")}>&times;</button>

        {st.category && (
          <span class="session-modal__category">
            {t(lang, categoryKeys[st.category] || `booking.category.${st.category}`)}
          </span>
        )}
        <h2 class="session-modal__title" id={`modal-title-${st.slug}`}>{st.name}</h2>

        <div class="session-modal__meta">
          <span>{t(lang, "booking.duration")}: {st.durationMinutes} {t(lang, "booking.minutes")}</span>
          <span>{t(lang, "booking.maxDogs")}: {st.maxDogs}</span>
          <span class="session-modal__price">{st.basePrice} {st.currency}</span>
        </div>

        {st.description && (
          <p class="session-modal__description">{st.description}</p>
        )}

        {st.includes && st.includes.length > 0 && (
          <>
            <h3 class="session-modal__section-title">{t(lang, "booking.detail.whatIncluded")}</h3>
            <ul class="session-modal__includes">
              {st.includes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </>
        )}

        <button type="button" class="session-modal__cta" data-open-calendar={st.slug}>
          {t(lang, "booking.bookThisSession")}
        </button>

        <h3 class="session-modal__section-title">{t(lang, "booking.detail.faq")}</h3>
        <div class="booking-faq">
          <details class="booking-faq__item">
            <summary>{t(lang, "booking.detail.faq.howLong")}</summary>
            <p>{t(lang, "booking.detail.faq.howLongAnswer")}</p>
          </details>
          <details class="booking-faq__item">
            <summary>{t(lang, "booking.detail.faq.howMany")}</summary>
            <p>{t(lang, "booking.detail.faq.howManyAnswer")}</p>
          </details>
          <details class="booking-faq__item">
            <summary>{t(lang, "booking.detail.faq.where")}</summary>
            <p>{t(lang, "booking.detail.faq.whereAnswer")}</p>
          </details>
        </div>
      </div>
    </div>
  ))}

  <!-- Calendar modal -->
  <div class="calendar-modal-overlay" id="calendar-modal" data-modal style="display:none;">
    <div class="calendar-modal" role="dialog" aria-labelledby="calendar-modal-title">
      <button type="button" class="calendar-modal__close" data-close-modal aria-label={t(lang, "portfolio.close")}>&times;</button>
      <h2 class="calendar-modal__title" id="calendar-modal-title">{t(lang, "booking.calendar.title")}</h2>
      <p class="calendar-modal__subtitle">{t(lang, "booking.calendar.subtitle")}</p>
      <BookingCalendar
        lang={lang}
        sessionTypes={sessionTypes}
        initialSlots={initialSlots}
        initialMonth={currentMonth}
        initialYear={currentYear}
        apiBase={apiBase}
        confirmPath="/en/booking/confirmation"
        translations={calendarTranslations}
      />
    </div>
  </div>

  <!-- How it works -->
  <section class="how-it-works reveal">
    <h2 class="how-it-works__title">{t(lang, "booking.howItWorks.title")}</h2>
    <div class="how-it-works__steps reveal-stagger">
      <div class="how-it-works__step reveal">
        <div class="how-it-works__number">1</div>
        <h3 class="how-it-works__step-title">{t(lang, "booking.howItWorks.step1.title")}</h3>
        <p class="how-it-works__step-text">{t(lang, "booking.howItWorks.step1.text")}</p>
      </div>
      <div class="how-it-works__step reveal">
        <div class="how-it-works__number">2</div>
        <h3 class="how-it-works__step-title">{t(lang, "booking.howItWorks.step2.title")}</h3>
        <p class="how-it-works__step-text">{t(lang, "booking.howItWorks.step2.text")}</p>
      </div>
      <div class="how-it-works__step reveal">
        <div class="how-it-works__number">3</div>
        <h3 class="how-it-works__step-title">{t(lang, "booking.howItWorks.step3.title")}</h3>
        <p class="how-it-works__step-text">{t(lang, "booking.howItWorks.step3.text")}</p>
      </div>
    </div>
  </section>

  <!-- Trust signals -->
  <div class="trust-strip reveal">
    <div class="trust-strip__item">
      <span class="trust-strip__number">{t(lang, "booking.trust.sessions")}</span>
      <span class="trust-strip__label">{t(lang, "booking.trust.sessionsLabel")}</span>
    </div>
    <div class="trust-strip__item">
      <span class="trust-strip__number">{t(lang, "booking.trust.experience")}</span>
      <span class="trust-strip__label">{t(lang, "booking.trust.experienceLabel")}</span>
    </div>
    <div class="trust-strip__item">
      <span class="trust-strip__number">{t(lang, "booking.trust.photos")}</span>
      <span class="trust-strip__label">{t(lang, "booking.trust.photosLabel")}</span>
    </div>
  </div>

  <!-- Testimonials -->
  <section class="testimonials reveal">
    <h2 class="testimonials__title">{t(lang, "booking.testimonials.title")}</h2>
    <div class="testimonials__grid reveal-stagger">
      {[1, 2, 3].map((i) => (
        <div class="testimonials__card reveal">
          <p class="testimonials__quote">{t(lang, `booking.testimonials.${i}.text`)}</p>
          <p class="testimonials__author">{t(lang, `booking.testimonials.${i}.author`)}</p>
          <p class="testimonials__dog">{t(lang, `booking.testimonials.${i}.dog`)}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- About the photographer -->
  <section class="about-photographer reveal">
    <div class="about-photographer__avatar">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
    </div>
    <h2 class="about-photographer__title">{t(lang, "booking.about.title")}</h2>
    <p class="about-photographer__text">{t(lang, "booking.about.text")}</p>
  </section>

  <!-- Bottom CTA -->
  <div class="booking-cta-banner reveal">
    <h2 class="booking-cta-banner__title">{t(lang, "booking.cta.title")}</h2>
    <p class="booking-cta-banner__text">{t(lang, "booking.cta.text")}</p>
    <button type="button" class="booking-cta-banner__button" id="cta-open-calendar">
      {t(lang, "booking.cta.button")}
    </button>
  </div>
</BaseLayout>

<script>
  function closeAllModals() {
    document.querySelectorAll<HTMLElement>(".session-modal-overlay--open, .calendar-modal-overlay--open").forEach((el) => {
      el.classList.remove("session-modal-overlay--open", "calendar-modal-overlay--open");
      if (el.id === "calendar-modal") {
        el.addEventListener("transitionend", () => { el.style.display = "none"; }, { once: true });
      }
    });
    document.body.style.overflow = "";
  }

  function closeOverlay(overlay: HTMLElement) {
    overlay.classList.remove("session-modal-overlay--open", "calendar-modal-overlay--open");
    if (overlay.id === "calendar-modal") {
      overlay.addEventListener("transitionend", () => { overlay.style.display = "none"; }, { once: true });
    }
    if (!document.querySelector(".session-modal-overlay--open, .calendar-modal-overlay--open")) {
      document.body.style.overflow = "";
    }
  }

  function openCalendarModal() {
    const calModal = document.getElementById("calendar-modal");
    if (!calModal) return;
    calModal.style.display = "";
    void calModal.offsetHeight;
    calModal.classList.add("calendar-modal-overlay--open");
    document.body.style.overflow = "hidden";
  }

  function initModals() {
    document.querySelectorAll<HTMLElement>("[data-open-modal]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.dataset.openModal;
        const overlay = document.getElementById(`modal-${slug}`);
        if (overlay) {
          overlay.classList.add("session-modal-overlay--open");
          document.body.style.overflow = "hidden";
        }
      });
    });

    document.querySelectorAll<HTMLElement>("[data-open-calendar]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const slug = btn.dataset.openCalendar;
        closeAllModals();

        const sessionSelect = document.getElementById("session-type-select") as HTMLSelectElement | null;
        if (sessionSelect && slug) {
          for (const opt of sessionSelect.options) {
            if (opt.dataset.slug === slug) {
              sessionSelect.value = opt.value;
              sessionSelect.dispatchEvent(new Event("change"));
              break;
            }
          }
        }

        requestAnimationFrame(() => openCalendarModal());
      });
    });

    document.querySelectorAll<HTMLElement>("[data-close-modal]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const overlay = btn.closest("[data-modal]") as HTMLElement | null;
        if (overlay) closeOverlay(overlay);
      });
    });

    document.querySelectorAll<HTMLElement>("[data-modal]").forEach((overlay) => {
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closeOverlay(overlay);
      });
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAllModals();
    });

    document.getElementById("cta-open-calendar")?.addEventListener("click", () => openCalendarModal());
  }

  function initReveal() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReduced) {
      document.querySelectorAll(".reveal").forEach((el) => el.classList.add("reveal--visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("reveal--visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
  }

  initModals();
  initReveal();
  document.addEventListener("astro:after-swap", () => { initModals(); initReveal(); });
</script>

<style lang="scss">
  @use "../../../styles/components/booking";
  @use "../../../styles/components/booking-calendar";
</style>
