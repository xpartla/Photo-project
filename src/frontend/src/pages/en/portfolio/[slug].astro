---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import ResponsiveImage from "../../../components/ResponsiveImage.astro";
import { getPhoto } from "../../../lib/api";
import { t } from "../../../lib/i18n";
import { getFallbackUrl } from "../../../lib/imageUrl";

const lang = "en";
const { slug } = Astro.params;

let photo;
try {
  photo = await getPhoto(slug!, lang);
} catch {
  return Astro.redirect("/en/portfolio");
}

const pageTitle = `${photo.title || photo.slug} — Portfolio — DogPhoto`;
const pageDescription = photo.description || photo.altText || t(lang, "portfolio.description");
const ogImage = getFallbackUrl(photo.variants);

const hasTechnicalDetails = photo.cameraSettings || photo.location || photo.shotDate;
const rotations = [-2, 1.5, -1, 2.5, -0.5, 1, -1.5, 0.5];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ImageObject",
    name: photo.title,
    description: photo.description || photo.altText,
    contentUrl: ogImage,
    author: { "@type": "Person", name: "DogPhoto" },
    ...(photo.shotDate && { datePublished: photo.shotDate }),
    ...(photo.cameraSettings && {
      exifData: [
        { "@type": "PropertyValue", name: "Camera Settings", value: photo.cameraSettings },
      ],
    }),
    ...(photo.location && {
      contentLocation: { "@type": "Place", name: photo.location },
    }),
    ...(photo.tags.length > 0 && {
      keywords: photo.tags.map((tag) => tag.name).join(", "),
    }),
    inLanguage: "en",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path={`/en/portfolio/${slug}`}
    ogType="article"
    ogImage={ogImage}
    ogImageWidth={photo.width || undefined}
    ogImageHeight={photo.height || undefined}
    jsonLd={jsonLd}
  />

  <article class="detail">
    <!-- Background decorations -->
    <div class="detail__deco" aria-hidden="true">
      <svg class="detail__sparkle detail__sparkle--1" viewBox="0 0 24 24">
        <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#F2B880" />
      </svg>
      <svg class="detail__sparkle detail__sparkle--2" viewBox="0 0 24 24">
        <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#B8A0C8" />
      </svg>
      <svg class="detail__sparkle detail__sparkle--3" viewBox="0 0 24 24">
        <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#D97B8F" />
      </svg>
      <svg class="detail__circle detail__circle--1" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" stroke="#F2B880" stroke-width="3" fill="none" stroke-dasharray="8 6" />
      </svg>
      <svg class="detail__circle detail__circle--2" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" stroke="#B8A0C8" stroke-width="3" fill="none" stroke-dasharray="8 6" />
      </svg>
    </div>

    <!-- Breadcrumb -->
    <nav class="detail__breadcrumb" data-reveal>
      <a href="/en/portfolio" class="detail__back">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        {t(lang, "portfolio.backToPortfolio")}
      </a>
    </nav>

    <!-- Image showcase -->
    <section class="showcase" data-reveal>
      <div class="showcase__frame">
        <ResponsiveImage
          variants={photo.variants}
          alt={photo.altText || photo.title || ""}
          width={photo.width || 1200}
          height={photo.height || 800}
          dominantColor={photo.dominantColor}
          blurhash={photo.blurhash}
          loading="eager"
          fetchpriority="high"
          sizes="(max-width: 768px) 96vw, (max-width: 1200px) 80vw, 1100px"
        />
      </div>
    </section>

    <!-- Info panel -->
    <section class="info" data-reveal>
      <div class="info__content">
        {photo.title && (
          <h1 class="info__title">
            {photo.title}
            <svg class="info__underline" viewBox="0 0 300 12" fill="none" aria-hidden="true">
              <path
                d="M0 6 Q25 0 50 6 Q75 12 100 6 Q125 0 150 6 Q175 12 200 6 Q225 0 250 6 Q275 12 300 6"
                stroke="#F2B880"
                stroke-width="4"
                stroke-linecap="round"
              />
            </svg>
          </h1>
        )}

        {photo.description && <p class="info__description">{photo.description}</p>}

        {photo.tags.length > 0 && (
          <div class="info__tags">
            {photo.tags.map((tag) => (
              <a href={`/en/portfolio?tag=${tag.slug}`} class="tag-pill">{tag.name}</a>
            ))}
          </div>
        )}

        <!-- Action buttons -->
        <div class="info__actions">
          <span class="action-btn action-btn--primary">
            {t(lang, "portfolio.buyAsPrint")}
          </span>
          <a href="/en/booking" class="action-btn action-btn--secondary">
            {t(lang, "portfolio.bookSession")}
          </a>
        </div>

        {photo.collections.length > 0 && (
          <div class="info__collections">
            {photo.collections.map((col) => (
              <a href={`/en/portfolio/collections/${col.slug}`} class="collection-link">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                  <line x1="3" y1="9" x2="21" y2="9" />
                  <line x1="9" y1="21" x2="9" y2="9" />
                </svg>
                {col.name}
              </a>
            ))}
          </div>
        )}

        <!-- Technical details - collapsible -->
        {hasTechnicalDetails && (
          <details class="tech-details">
            <summary class="tech-details__toggle">
              <svg class="tech-details__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
              </svg>
              {t(lang, "portfolio.technicalDetails")}
              <svg class="tech-details__chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="tech-details__body">
              {photo.cameraSettings && (
                <div class="tech-row">
                  <span class="tech-row__label">{t(lang, "portfolio.cameraSettings")}</span>
                  <span class="tech-row__value">{photo.cameraSettings}</span>
                </div>
              )}
              {photo.location && (
                <div class="tech-row">
                  <span class="tech-row__label">{t(lang, "portfolio.location")}</span>
                  <span class="tech-row__value">{photo.location}</span>
                </div>
              )}
              {photo.shotDate && (
                <div class="tech-row">
                  <span class="tech-row__label">{t(lang, "portfolio.shotDate")}</span>
                  <span class="tech-row__value">{new Date(photo.shotDate).toLocaleDateString("en-US")}</span>
                </div>
              )}
            </div>
          </details>
        )}
      </div>
    </section>

    <!-- Related photos -->
    {photo.relatedPhotos.length > 0 && (
      <section class="related" data-reveal>
        <div class="related__header">
          <h2 class="related__title">{t(lang, "portfolio.exploreMore")}</h2>
          <svg class="related__underline" viewBox="0 0 200 10" fill="none" aria-hidden="true">
            <path
              d="M0 5 Q17 0 33 5 Q50 10 67 5 Q83 0 100 5 Q117 10 133 5 Q150 0 167 5 Q183 10 200 5"
              stroke="#B8A0C8"
              stroke-width="3"
              stroke-linecap="round"
            />
          </svg>
        </div>
        <div class="related__track">
          {photo.relatedPhotos.map((rp, i) => (
            <a
              href={`/en/portfolio/${rp.slug}`}
              class="related-card"
              style={`--rotation: ${rotations[i % rotations.length]}deg; --delay: ${i * 0.08}s`}
            >
              <div class="related-card__frame">
                <ResponsiveImage
                  variants={rp.variants}
                  alt={rp.altText || rp.title || ""}
                  width={rp.width || 400}
                  height={rp.height || 300}
                  dominantColor={rp.dominantColor}
                  sizes="(max-width: 600px) 70vw, 280px"
                />
              </div>
              <span class="related-card__title">{rp.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style lang="scss">
  @use "sass:color";
  @use "../../../styles/variables" as *;

  // ── Keyframes ─────────────────────────────────────────
  @keyframes dropIn {
    0% { transform: translateY(-30px); opacity: 0; }
    60% { transform: translateY(4px); opacity: 1; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes drawLine {
    from { stroke-dashoffset: 320; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.6; }
    50% { transform: scale(1.3) rotate(20deg); opacity: 1; }
  }

  @keyframes gentleSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes frameIn {
    0% { transform: scale(0.92) rotate(-1deg); opacity: 0; }
    60% { transform: scale(1.01) rotate(0.3deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
  }

  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  // ── Detail container ──────────────────────────────────
  .detail {
    position: relative;
    overflow: hidden;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  // ── Background decorations ────────────────────────────
  .detail__deco {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .detail__sparkle {
    position: absolute;

    &--1 { top: 15%; left: 5%; width: 28px; animation: twinkle 3s ease-in-out infinite; }
    &--2 { top: 35%; right: 4%; width: 22px; animation: twinkle 3s ease-in-out 0.7s infinite; }
    &--3 { bottom: 20%; left: 8%; width: 20px; animation: twinkle 3s ease-in-out 1.4s infinite; }
  }

  .detail__circle {
    position: absolute;
    opacity: 0.08;

    &--1 { top: 10%; right: -3%; width: 200px; animation: gentleSpin 40s linear infinite; }
    &--2 { bottom: 5%; left: -4%; width: 160px; animation: gentleSpin 35s linear infinite reverse; }
  }

  // ── Breadcrumb ────────────────────────────────────────
  .detail__breadcrumb {
    position: relative;
    z-index: 1;
    padding: 1.5rem 0 1rem;
  }

  .detail__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.9rem;
    color: $dark;
    text-decoration: none;
    padding: 0.4rem 1rem 0.4rem 0.7rem;
    border: $outline-width solid $outline;
    border-radius: 8px;
    box-shadow: 2px 2px 0 $outline;
    background: $white;
    transition:
      transform $transition-fast,
      box-shadow $transition-fast,
      background $transition-fast;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 3px 4px 0 $outline;
      background: $peach;
    }

    &:active {
      transform: translateY(1px);
      box-shadow: 1px 1px 0 $outline;
    }
  }

  // ── Image showcase ────────────────────────────────────
  .showcase {
    position: relative;
    z-index: 1;
    margin-bottom: 2.5rem;
  }

  .showcase__frame {
    background: #fff;
    padding: 12px;
    border: $outline-width-thick solid $outline;
    border-radius: 6px;
    box-shadow: 5px 5px 0 $outline;
    animation: frameIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    transition: box-shadow 0.4s ease;

    &:hover {
      box-shadow: 7px 8px 0 $outline;
    }

    :global(picture) {
      display: block;
    }

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
      max-height: calc(100vh - 200px);
      object-fit: contain;
      border-radius: 3px;
    }
  }

  // ── Info panel ────────────────────────────────────────
  .info {
    position: relative;
    z-index: 1;
    margin-bottom: 3rem;
  }

  .info__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .info__title {
    font-family: $font-heading;
    font-size: 2.8rem;
    color: $dark;
    margin: 0 0 1rem;
    text-align: center;
    animation: dropIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .info__underline {
    display: block;
    width: 180px;
    height: 12px;
    margin: -4px auto 0;

    path {
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1s ease 0.3s forwards;
    }
  }

  .info__description {
    font-family: $font-body;
    font-size: 1.15rem;
    font-weight: 600;
    color: $dark;
    line-height: 1.7;
    text-align: center;
    max-width: 650px;
    margin: 1.25rem auto 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.5s forwards;
  }

  // ── Tags ──────────────────────────────────────────────
  .info__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.6s forwards;
  }

  .tag-pill {
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.3rem 0.9rem;
    background: rgba($lavender, 0.15);
    border: 2px solid $lavender;
    border-radius: 20px;
    color: $dark;
    text-decoration: none;
    transition:
      background $transition-fast,
      transform $transition-fast,
      box-shadow $transition-fast;

    &:hover {
      background: $lavender;
      color: $white;
      transform: translateY(-2px);
      box-shadow: 2px 3px 0 $outline;
    }
  }

  // ── Action buttons ────────────────────────────────────
  .info__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.7s forwards;
  }

  .action-btn {
    font-family: $font-body;
    font-weight: 800;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    padding: 0.7rem 1.8rem;
    border: $outline-width-thick solid $outline;
    border-radius: 10px;
    box-shadow: 4px 4px 0 $outline;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform $transition-fast,
      box-shadow $transition-fast,
      background $transition-fast;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 5px 6px 0 $outline;
    }

    &:active {
      transform: translateY(1px);
      box-shadow: 2px 2px 0 $outline;
    }

    &--primary {
      background: $peach;
      color: $dark;

      background-image: linear-gradient(
        110deg,
        transparent 25%,
        rgba(255, 255, 255, 0.3) 37%,
        transparent 50%
      );
      background-size: 200% 100%;
      animation: shimmer 3s ease-in-out infinite 2s;

      &:hover { background-color: color.adjust($peach, $lightness: -5%); }
    }

    &--secondary {
      background: $sage;
      color: $white;

      &:hover { background: color.adjust($sage, $lightness: -8%); }
    }
  }

  // ── Collections ───────────────────────────────────────
  .info__collections {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .collection-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.9rem;
    color: $dark;
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    border: 2px solid $terracotta;
    border-radius: 8px;
    background: rgba($terracotta, 0.08);
    transition:
      background $transition-fast,
      transform $transition-fast,
      color $transition-fast;

    &:hover {
      background: $terracotta;
      color: $white;
      transform: translateY(-2px);
    }
  }

  // ── Technical details (collapsible) ───────────────────
  .tech-details {
    max-width: 500px;
    margin: 0 auto 1rem;
    border: $outline-width solid $outline;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 3px 3px 0 $outline;
    background: $white;
  }

  .tech-details__toggle {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.9rem;
    color: $dark;
    cursor: pointer;
    list-style: none;
    transition: background $transition-fast;

    &::-webkit-details-marker {
      display: none;
    }

    &:hover {
      background: rgba($peach, 0.1);
    }
  }

  .tech-details__icon {
    flex-shrink: 0;
    color: $terracotta;
  }

  .tech-details__chevron {
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: $dark;
  }

  .tech-details[open] .tech-details__chevron {
    transform: rotate(180deg);
  }

  .tech-details__body {
    padding: 0 1rem 1rem;
    border-top: 2px dashed rgba($outline, 0.15);
  }

  .tech-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    font-family: $font-body;
    font-size: 0.9rem;

    & + & {
      border-top: 1px solid rgba($outline, 0.08);
    }
  }

  .tech-row__label {
    font-weight: 700;
    color: $terracotta;
  }

  .tech-row__value {
    color: $dark;
    text-align: right;
    font-weight: 600;
  }

  // ── Related photos ────────────────────────────────────
  .related {
    position: relative;
    z-index: 1;
    padding-top: 1rem;
  }

  .related__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .related__title {
    font-family: $font-heading;
    font-size: 2rem;
    color: $dark;
    margin: 0;
  }

  .related__underline {
    display: block;
    width: 150px;
    height: 10px;
    margin: 0 auto;

    path {
      stroke-dasharray: 250;
      stroke-dashoffset: 250;
    }
  }

  .related.revealed .related__underline path {
    animation: drawLine 1s ease 0.3s forwards;
  }

  .related__track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    overflow-y: visible;
    padding: 1rem 0.5rem 2rem;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;

    mask-image: linear-gradient(to right, transparent, black 2%, black 98%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 2%, black 98%, transparent);
  }

  .related-card {
    flex: 0 0 260px;
    scroll-snap-align: center;
    text-decoration: none;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease var(--delay, 0s),
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) var(--delay, 0s);
  }

  .related.revealed .related-card {
    opacity: 1;
    transform: translateY(0);
  }

  .related-card__frame {
    background: #fff;
    padding: 8px;
    border: $outline-width solid $outline;
    border-radius: 4px;
    box-shadow: 3px 3px 0 $outline;
    overflow: hidden;
    transform: rotate(var(--rotation, 0deg));
    transition:
      transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.35s ease,
      border-color 0.35s ease;

    :global(picture) { display: block; }

    :global(img) {
      display: block;
      width: 100%;
      height: 180px;
      object-fit: cover;
      border-radius: 2px;
      transition: transform 0.4s ease;
    }
  }

  .related-card__title {
    display: block;
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.9rem;
    color: $dark;
    padding: 0.5rem 0.25rem 0;
    transition: color $transition-fast;
  }

  @media (hover: hover) {
    .related-card:hover .related-card__frame {
      transform: rotate(0deg) translateY(-6px);
      box-shadow: 5px 7px 0 $outline;
      border-color: $lavender;
    }

    .related-card:hover .related-card__frame :global(img) {
      transform: scale(1.06);
    }

    .related-card:hover .related-card__title {
      color: $lavender;
    }
  }

  // ── Data-reveal animation trigger ─────────────────────
  [data-reveal] {
    &.revealed {
      // Class added by JS — child animations play on reveal
    }
  }

  // ── Responsive: Tablet ────────────────────────────────
  @media (max-width: $breakpoint-lg) {
    .info__title {
      font-size: 2.2rem;
    }

    .related__title {
      font-size: 1.6rem;
    }

    .detail__sparkle {
      &--1 { width: 22px; }
      &--2 { width: 18px; }
      &--3 { width: 16px; }
