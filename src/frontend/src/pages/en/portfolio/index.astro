---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import PortfolioSplit from "../../../components/PortfolioSplit.astro";
import PortfolioFilter from "../../../components/PortfolioFilter.astro";
import { getPhotos, getTags, getCollections } from "../../../lib/api";
import { t } from "../../../lib/i18n";
import type { PhotoSummary, TagSummary, CollectionSummary } from "../../../lib/api";

const lang = "en";

let filmPhotos: PhotoSummary[] = [];
let digitalPhotos: PhotoSummary[] = [];
let tags: TagSummary[] = [];
let collections: CollectionSummary[] = [];
try {
  const [films, digitals, tg, cols] = await Promise.all([
    getPhotos({ size: 50, tag: "film", lang }),
    getPhotos({ size: 50, tag: "digital", lang }),
    getTags(lang),
    getCollections(lang),
  ]);
  filmPhotos = films.items;
  digitalPhotos = digitals.items;
  tags = tg;
  collections = cols;
} catch {
  filmPhotos = [];
  digitalPhotos = [];
}

const pageTitle = `${t(lang, "portfolio.title")} — DogPhoto`;
const pageDescription = t(lang, "portfolio.description");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: t(lang, "portfolio.title"),
  description: pageDescription,
  author: { "@type": "Person", name: "DogPhoto" },
  inLanguage: lang,
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path="/en/portfolio"
    jsonLd={jsonLd}
  />

  <PortfolioSplit
    lang={lang}
    filmPhotos={filmPhotos}
    digitalPhotos={digitalPhotos}
    labels={{
      title: t(lang, "portfolio.title"),
      subtitle: t(lang, "portfolio.heroSubtitle"),
      filmSection: t(lang, "portfolio.filmSection"),
      digitalSection: t(lang, "portfolio.digitalSection"),
      viewDetail: t(lang, "portfolio.viewDetail"),
      buyAsPrint: t(lang, "portfolio.buyAsPrint"),
      close: t(lang, "portfolio.close"),
      noPhotos: t(lang, "portfolio.noPhotos"),
    }}
  >
    <PortfolioFilter
      lang={lang}
      collections={collections}
      tags={tags}
      labels={{
        filter: t(lang, "portfolio.filter"),
        allPhotos: t(lang, "portfolio.allPhotos"),
        collections: t(lang, "portfolio.collections"),
        tags: t(lang, "portfolio.tags"),
      }}
    />
  </PortfolioSplit>
</BaseLayout>
