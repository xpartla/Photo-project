---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import BlogDetail from "../../../components/BlogDetail.astro";
import { getBlogPost, type BlogPostDetail } from "../../../lib/api";
import { t } from "../../../lib/i18n";

const lang = "sk";
const { slug } = Astro.params;
const pageUrl = Astro.url.pathname;

let post: BlogPostDetail | null = null;
try {
  post = await getBlogPost(slug!, lang);
} catch {
  return Astro.redirect(`/${lang}/blog`, 302);
}

if (!post) {
  return Astro.redirect(`/${lang}/blog`, 302);
}

const pageTitle = `${post.metaTitle ?? post.title} — PartlPhoto`;
const description = post.metaDescription ?? post.excerpt ?? t(lang, "blog.description");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": description,
  "datePublished": post.publishedAt,
  "author": { "@type": "Person", "name": post.author ?? "Adam Partl" },
  "publisher": {
    "@type": "Organization",
    "name": "PartlPhoto",
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl },
  "keywords": post.tags.map((t) => t.name).join(", "),
  ...(post.featuredImageUrl ? { image: post.featuredImageUrl } : {}),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t(lang, "blog.title"), "item": `/${lang}/blog` },
    { "@type": "ListItem", "position": 2, "name": post.title, "item": pageUrl },
  ],
};
---

<BaseLayout title={pageTitle} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={description}
    lang={lang}
    path={pageUrl}
    ogType="article"
    ogImage={post.featuredImageUrl}
    jsonLd={[jsonLd, breadcrumb]}
  />

  <main>
    <BlogDetail
      lang={lang}
      post={post}
      blogBaseUrl={`/${lang}/blog`}
      categoryBaseUrl={`/${lang}/blog/kategoria`}
      tagBaseUrl={`/${lang}/blog/tag`}
    />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../styles/components/blog-detail";
</style>
