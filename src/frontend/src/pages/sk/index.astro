---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeContent from "../../components/HomeContent.astro";
import { getPhotos } from "../../lib/api";
import { t } from "../../lib/i18n";

const lang = "sk";

let filmPhotos = [];
let digitalPhotos = [];

try {
  const [filmResult, digitalResult] = await Promise.all([
    getPhotos({ tag: "film", size: 7, lang }),
    getPhotos({ tag: "digital", size: 7, lang }),
  ]);
  filmPhotos = filmResult.items;
  digitalPhotos = digitalResult.items;
} catch (e) {
  console.error("Failed to fetch home photos:", e);
}
---

<BaseLayout title={t(lang, "site.title")} lang={lang}>
  <HomeContent
    lang={lang}
    filmPhotos={filmPhotos}
    digitalPhotos={digitalPhotos}
    labels={{
      tagline: t(lang, "home.tagline"),
      subtitle: t(lang, "home.subtitle"),
      ctaPortfolio: t(lang, "home.ctaPortfolio"),
      ctaBooking: t(lang, "home.ctaBooking"),
      filmPhotos: t(lang, "home.filmPhotos"),
      digitalPhotos: t(lang, "home.digitalPhotos"),
      shopLinkText: t(lang, "home.viewInShop"),
      ctaBanner: t(lang, "home.ctaBanner"),
      ctaBannerSub: t(lang, "home.ctaBannerSub"),
      ctaBookNow: t(lang, "home.ctaBookNow"),
    }}
  />
</BaseLayout>
