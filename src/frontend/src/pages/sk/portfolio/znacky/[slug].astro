---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../../components/SeoMeta.astro";
import PortfolioHero from "../../../../components/PortfolioHero.astro";
import PortfolioFilter from "../../../../components/PortfolioFilter.astro";
import PortfolioGallery from "../../../../components/PortfolioGallery.astro";
import { getPhotos, getTags, getCollections } from "../../../../lib/api";
import { t } from "../../../../lib/i18n";
import type { PhotoSummary, TagSummary, CollectionSummary } from "../../../../lib/api";

const lang = "sk";
const { slug } = Astro.params;

let photos: PhotoSummary[] = [];
let tags: TagSummary[] = [];
let collections: CollectionSummary[] = [];
let activeTag: TagSummary | undefined;
try {
  [tags, collections] = await Promise.all([getTags(lang), getCollections(lang)]);
  activeTag = tags.find((tg) => tg.slug === slug);
  if (!activeTag) return Astro.redirect("/sk/portfolio");
  const result = await getPhotos({ tag: slug, size: 60, lang });
  photos = result.items;
} catch {
  return Astro.redirect("/sk/portfolio");
}

const pageTitle = `${activeTag.name} — Portfólio — DogPhoto`;
const pageDescription = `${activeTag.name} — ${activeTag.photoCount} ${t(lang, "portfolio.photosTagged")}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: activeTag.name,
  description: pageDescription,
  author: { "@type": "Person", name: "DogPhoto" },
  inLanguage: lang,
  numberOfItems: activeTag.photoCount,
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path={`/sk/portfolio/znacky/${slug}`}
    jsonLd={jsonLd}
  />

  <PortfolioHero
    title={activeTag.name}
    subtitle={`${activeTag.photoCount} ${t(lang, "portfolio.photosTagged")}`}
  />

  <PortfolioFilter
    lang={lang}
    collections={collections}
    tags={tags}
    active={{ type: "tag", slug: slug! }}
    labels={{
      filter: t(lang, "portfolio.filter"),
      allPhotos: t(lang, "portfolio.allPhotos"),
      collections: t(lang, "portfolio.collections"),
      tags: t(lang, "portfolio.tags"),
    }}
  />

  <PortfolioGallery
    lang={lang}
    photos={photos}
    labels={{
      viewDetail: t(lang, "portfolio.viewDetail"),
      buyAsPrint: t(lang, "portfolio.buyAsPrint"),
      close: t(lang, "portfolio.close"),
      noPhotos: t(lang, "portfolio.noPhotos"),
    }}
  />
</BaseLayout>
