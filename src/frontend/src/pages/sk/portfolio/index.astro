---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../components/SeoMeta.astro";
import PortfolioSplit from "../../../components/PortfolioSplit.astro";
import { getPhotos } from "../../../lib/api";
import { t } from "../../../lib/i18n";
import type { PhotoSummary } from "../../../lib/api";

const lang = "sk";

let dogPhotos: PhotoSummary[];
let filmPhotos: PhotoSummary[];
try {
  const [dogs, films] = await Promise.all([
    getPhotos({ size: 50, tag: "dog", lang }),
    getPhotos({ size: 50, tag: "film", lang }),
  ]);
  dogPhotos = dogs.items;
  filmPhotos = films.items;
} catch {
  dogPhotos = [];
  filmPhotos = [];
}

const pageTitle = `${t(lang, "portfolio.title")} — DogPhoto`;
const pageDescription = t(lang, "portfolio.description");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: t(lang, "portfolio.title"),
  description: pageDescription,
  author: { "@type": "Person", name: "DogPhoto" },
  inLanguage: lang,
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path="/sk/portfolio"
    jsonLd={jsonLd}
  />

  <PortfolioSplit
    lang={lang}
    dogPhotos={dogPhotos}
    filmPhotos={filmPhotos}
    labels={{
      title: t(lang, "portfolio.title"),
      subtitle: t(lang, "portfolio.heroSubtitle"),
      dogSection: t(lang, "portfolio.dogSection"),
      filmSection: t(lang, "portfolio.filmSection"),
      viewDetail: t(lang, "portfolio.viewDetail"),
      buyAsPrint: t(lang, "portfolio.buyAsPrint"),
      close: t(lang, "portfolio.close"),
      noPhotos: t(lang, "portfolio.noPhotos"),
    }}
  />
</BaseLayout>
