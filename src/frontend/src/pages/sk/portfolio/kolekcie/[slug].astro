---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../../components/SeoMeta.astro";
import PortfolioHero from "../../../../components/PortfolioHero.astro";
import PortfolioFilter from "../../../../components/PortfolioFilter.astro";
import PortfolioGallery from "../../../../components/PortfolioGallery.astro";
import { getCollection, getCollections, getTags } from "../../../../lib/api";
import { t } from "../../../../lib/i18n";
import type { TagSummary, CollectionSummary } from "../../../../lib/api";

const lang = "sk";
const { slug } = Astro.params;

let collection;
let tags: TagSummary[] = [];
let collections: CollectionSummary[] = [];
try {
  const [col, tg, cols] = await Promise.all([
    getCollection(slug!, { lang, page: 1, size: 60 }),
    getTags(lang),
    getCollections(lang),
  ]);
  collection = col;
  tags = tg;
  collections = cols;
} catch {
  return Astro.redirect("/sk/portfolio");
}

const pageTitle = `${collection.name} — Portfólio — DogPhoto`;
const pageDescription = collection.description || `${collection.name} — kolekcia fotografií`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  name: collection.name,
  description: pageDescription,
  author: { "@type": "Person", name: "DogPhoto" },
  inLanguage: "sk",
  numberOfItems: collection.photos.totalCount,
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={pageDescription}
    lang={lang}
    path={`/sk/portfolio/kolekcie/${slug}`}
    jsonLd={jsonLd}
  />

  <PortfolioHero title={collection.name} subtitle={collection.description} />

  <PortfolioFilter
    lang={lang}
    collections={collections}
    tags={tags}
    active={{ type: "collection", slug: slug! }}
    labels={{
      filter: t(lang, "portfolio.filter"),
      allPhotos: t(lang, "portfolio.allPhotos"),
      collections: t(lang, "portfolio.collections"),
      tags: t(lang, "portfolio.tags"),
    }}
  />

  <PortfolioGallery
    lang={lang}
    photos={collection.photos.items}
    labels={{
      viewDetail: t(lang, "portfolio.viewDetail"),
      buyAsPrint: t(lang, "portfolio.buyAsPrint"),
      close: t(lang, "portfolio.close"),
      noPhotos: t(lang, "portfolio.noPhotos"),
    }}
  />
</BaseLayout>
