---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import BlogPostEditor from "../../../../components/BlogPostEditor.astro";
import { t } from "../../../../lib/i18n";

const lang = "sk";
const pageTitle = `${t(lang, "admin.blog.newPost")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <BlogPostEditor lang={lang} mode="create" />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../styles/components/admin";
</style>
