---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { t } from "../../../../lib/i18n";

const lang = "sk";
const pageTitle = `${t(lang, "admin.blog")} — ${t(lang, "admin.title")} — PartlPhoto`;
const apiBase = import.meta.env.PUBLIC_CLIENT_API_URL || "http://localhost:5000";
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin" data-admin-root hidden>
    <header class="admin__header">
      <a href={`/${lang}/admin`} class="admin__back">← {t(lang, "admin.title")}</a>
      <h1 class="admin__title">{t(lang, "admin.blog.allPosts")}</h1>
      <a href={`/${lang}/admin/blog/novy`} class="admin__primary-btn">+ {t(lang, "admin.blog.newPost")}</a>
    </header>

    <section class="admin-list">
      <div id="admin-posts-empty" class="admin-list__empty" hidden>
        <p>{t(lang, "admin.blog.noPosts")}</p>
        <a href={`/${lang}/admin/blog/novy`} class="admin__primary-btn">{t(lang, "admin.blog.createFirst")}</a>
      </div>
      <ul id="admin-posts" class="admin-list__items"></ul>
    </section>
  </main>

  <script id="admin-blog-config" type="application/json" set:html={JSON.stringify({
    apiBase, lang,
    t: {
      view: t(lang, "admin.blog.view"),
      edit: t(lang, "admin.blog.edit"),
      del: t(lang, "admin.blog.delete"),
      confirmDelete: t(lang, "admin.blog.confirmDelete"),
      statusDraft: t(lang, "blog.status.draft"),
      statusPublished: t(lang, "blog.status.published"),
      statusScheduled: t(lang, "blog.status.scheduled"),
      noPosts: t(lang, "admin.blog.noPosts"),
    }
  })}></script>

  <script>
    import { requireAdmin } from "../../../../lib/admin";

    const cfg = JSON.parse(document.getElementById("admin-blog-config")!.textContent!);
    const token = requireAdmin(cfg.lang);
    if (!token) throw new Error("not admin");

    const root = document.querySelector("[data-admin-root]") as HTMLElement;
    root.hidden = false;

    const list = document.getElementById("admin-posts") as HTMLUListElement;
    const empty = document.getElementById("admin-posts-empty") as HTMLElement;

    async function load() {
      const res = await fetch(`${cfg.apiBase}/api/blog/posts?size=50&includeDrafts=true&lang=${cfg.lang}`, {
        headers: { Authorization: `Bearer ${token}` },
      });
      if (!res.ok) {
        list.innerHTML = `<li class="admin-list__error">Failed to load (${res.status})</li>`;
        return;
      }
      const data = await res.json();
      const items: any[] = data.items || [];
      if (items.length === 0) {
        empty.hidden = false;
        return;
      }
      list.innerHTML = items.map((p) => {
        const date = p.publishedAt ? new Date(p.publishedAt).toLocaleDateString() : "—";
        const statusLabel = p.status === "Published" ? cfg.t.statusPublished
          : p.status === "Scheduled" ? cfg.t.statusScheduled : cfg.t.statusDraft;
        const statusClass = p.status === "Published" ? "is-published"
          : p.status === "Scheduled" ? "is-scheduled" : "is-draft";
        const viewPath = cfg.lang === "sk" ? `/sk/blog/${p.slug}` : `/en/blog/${p.slug}`;
        const editPath = cfg.lang === "sk" ? `/sk/admin/blog/upravit/${p.id}` : `/en/admin/blog/edit/${p.id}`;
        return `
          <li class="admin-list__item">
            <div class="admin-list__main">
              <div>
                <span class="admin-list__status ${statusClass}">${statusLabel}</span>
                <a class="admin-list__title" href="${editPath}">${escapeHtml(p.title)}</a>
              </div>
              <div class="admin-list__meta">
                <span>${p.slug}</span>
                <span>${date}</span>
              </div>
            </div>
            <div class="admin-list__actions">
              <a href="${viewPath}" class="admin-list__btn admin-list__btn--ghost" target="_blank" rel="noopener">${cfg.t.view}</a>
              <a href="${editPath}" class="admin-list__btn">${cfg.t.edit}</a>
              <button class="admin-list__btn admin-list__btn--danger" data-delete-id="${p.id}">${cfg.t.del}</button>
            </div>
          </li>
        `;
      }).join("");

      list.querySelectorAll<HTMLButtonElement>("[data-delete-id]").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.deleteId!;
          if (!confirm(cfg.t.confirmDelete)) return;
          const res = await fetch(`${cfg.apiBase}/api/blog/posts/${id}`, {
            method: "DELETE",
            headers: { Authorization: `Bearer ${token}` },
          });
          if (res.ok) {
            btn.closest("li")?.remove();
            if (list.children.length === 0) empty.hidden = false;
          }
        });
      });
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c]!));
    }

    load();
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../styles/components/admin";
</style>
