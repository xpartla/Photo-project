---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { t } from "../../../lib/i18n";
import { STORE_ENABLED } from "../../../lib/features";

const lang = "sk";
const pageTitle = `${t(lang, "admin.title")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin admin--guarded" data-admin-root hidden>
    <header class="admin__header">
      <p class="admin__eyebrow">{t(lang, "admin.title")}</p>
      <h1 class="admin__title">{t(lang, "admin.welcome")}</h1>
      <p class="admin__subtitle">{t(lang, "admin.welcomeDescription")}</p>
    </header>

    <section class="admin__counts">
      <a class="admin__count-card" href={`/${lang}/admin/rezervacia`}>
        <strong data-count="bookings">—</strong>
        <span>{t(lang, "admin.dashboard.pendingBookings")}</span>
      </a>
      {STORE_ENABLED && (
        <a class="admin__count-card" href={`/${lang}/admin/obchod/orders`}>
          <strong data-count="orders">—</strong>
          <span>{t(lang, "admin.dashboard.pendingOrders")}</span>
        </a>
      )}
      <a class="admin__count-card" href={`/${lang}/admin/blog`}>
        <strong data-count="drafts">—</strong>
        <span>{t(lang, "admin.dashboard.draftPosts")}</span>
      </a>
    </section>

    <section class="admin__grid">
      <a class="admin__card admin__card--primary" href={`/${lang}/admin/blog`}>
        <h2 class="admin__card-title">{t(lang, "admin.blog")}</h2>
        <p class="admin__card-desc">{t(lang, "admin.blog.description")}</p>
      </a>
      <a class="admin__card" href={`/${lang}/admin/portfolio`}>
        <h2 class="admin__card-title">{t(lang, "admin.portfolio")}</h2>
        <p class="admin__card-desc">{t(lang, "admin.portfolio.description")}</p>
      </a>
      {STORE_ENABLED && (
        <a class="admin__card" href={`/${lang}/admin/obchod`}>
          <h2 class="admin__card-title">{t(lang, "admin.shop")}</h2>
          <p class="admin__card-desc">{t(lang, "admin.shop.description")}</p>
        </a>
      )}
      <a class="admin__card" href={`/${lang}/admin/rezervacia`}>
        <h2 class="admin__card-title">{t(lang, "admin.booking")}</h2>
        <p class="admin__card-desc">{t(lang, "admin.booking.description")}</p>
      </a>
    </section>
  </main>

  <p class="admin__notice" data-admin-denied hidden>{t(lang, "admin.notAuthorized")}</p>

  <script>
    import { requireAdmin } from "../../../lib/admin";
    import { listMyBookings, listBlogDrafts } from "../../../lib/admin-api";

    const token = requireAdmin("sk");
    if (token) {
      const root = document.querySelector("[data-admin-root]") as HTMLElement | null;
      if (root) root.hidden = false;

      // Counts run in the background; failures don't block the dashboard.
      (async () => {
        try {
          const bookings = await listMyBookings();
          const pending = bookings.filter((b) => b.status === "Pending").length;
          const el = document.querySelector("[data-count='bookings']");
          if (el) el.textContent = String(pending);
        } catch { /* leave em-dash */ }
        try {
          const drafts = await listBlogDrafts();
          const draftCount = (drafts.items || []).filter((p: any) => p.status === "Draft").length;
          const el = document.querySelector("[data-count='drafts']");
          if (el) el.textContent = String(draftCount);
        } catch { /* leave em-dash */ }
        // Pending orders count: there is no admin-wide order listing endpoint yet,
        // so the dashboard count stays as "—" and the user clicks through to see them.
      })();
    }
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../styles/components/admin";
</style>
