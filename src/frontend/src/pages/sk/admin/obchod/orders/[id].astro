---
import BaseLayout from "../../../../../layouts/BaseLayout.astro";
import AdminOrderDetail from "../../../../../components/AdminOrderDetail.astro";
import { t } from "../../../../../lib/i18n";

const lang = "sk";
const { id } = Astro.params;
const pageTitle = `${t(lang, "order.title")} — PartlPhoto`;
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="admin">
    <AdminOrderDetail lang={lang} id={id ?? ""} />
  </main>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../../../styles/components/admin";
  @use "../../../../../styles/components/account";
</style>
