---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import SeoMeta from "../../../../components/SeoMeta.astro";
import { t } from "../../../../lib/i18n";

const lang = "sk";
const { id } = Astro.params;
const params = Astro.url.searchParams;

const session = params.get("session") || null;
const clientName = params.get("name") || null;
const clientEmail = params.get("email") || null;
const price = params.get("price") || null;
const currency = params.get("currency") || "EUR";
const date = params.get("date") || null;
const time = params.get("time") || null;
const status = params.get("status") || "Pending";

const hasData = !!(session && clientName);

const pageTitle = `${t(lang, "booking.confirmation.title")} — PartlPhoto`;

const statusKeys: Record<string, string> = {
  Pending: "booking.status.pending",
  Confirmed: "booking.status.confirmed",
  Cancelled: "booking.status.cancelled",
};
---

<BaseLayout title={pageTitle} lang={lang}>
  <SeoMeta
    slot="head"
    title={pageTitle}
    description={t(lang, "booking.confirmation.message")}
    lang={lang}
    path={`/sk/rezervacia/potvrdenie/${id}`}
  />

  <main class="booking-confirmation">
    <div class="booking-confirmation__card">
      <div class="booking-confirmation__icon">&#10003;</div>
      <h1 class="booking-confirmation__title">{t(lang, "booking.confirmation.title")}</h1>
      <p class="booking-confirmation__message">{t(lang, "booking.confirmation.message")}</p>

      {hasData && (
        <>
          <dl class="booking-confirmation__summary">
            <dt>{t(lang, "booking.calendar.sessionType")}</dt>
            <dd>{session}</dd>

            {date && time && (
              <>
                <dt>{t(lang, "booking.duration")}</dt>
                <dd>{date} &middot; {time}</dd>
              </>
            )}

            <dt>{t(lang, "booking.form.name")}</dt>
            <dd>{clientName}</dd>

            <dt>{t(lang, "booking.confirmation.emailSent")}</dt>
            <dd>{clientEmail}</dd>

            {price && (
              <>
                <dt>{t(lang, "booking.price")}</dt>
                <dd>{price} {currency}</dd>
              </>
            )}
          </dl>

          <span class="booking-confirmation__status">
            {t(lang, statusKeys[status] || "booking.status.pending")}
          </span>
        </>
      )}

      <div class="booking-confirmation__actions">
        <a href="/sk" class="booking-confirmation__back">{t(lang, "booking.confirmation.backHome")}</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  @use "../../../../styles/components/booking";
</style>
