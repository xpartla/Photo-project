---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { t } from "../../../lib/i18n";

const lang = "sk";
const pageTitle = `${t(lang, "register.title")} — PartlPhoto`;
const apiBase = import.meta.env.PUBLIC_CLIENT_API_URL || "http://localhost:5000";
---

<BaseLayout title={pageTitle} lang={lang}>
  <main class="login">
    <div class="login__card">
      <h1 class="login__title">{t(lang, "register.title")}</h1>
      <p class="login__register-link" style="margin-top:0;margin-bottom:24px;">{t(lang, "register.subtitle")}</p>

      <form class="login__form" id="register-form">
        <div class="login__field">
          <label class="login__label" for="email">{t(lang, "register.email")}</label>
          <input class="login__input" id="email" type="email" required autocomplete="email" />
        </div>

        <div class="login__field">
          <label class="login__label" for="display-name">{t(lang, "register.displayName")}</label>
          <input class="login__input" id="display-name" type="text" required autocomplete="name" />
        </div>

        <div class="login__field">
          <label class="login__label" for="phone">{t(lang, "register.phone")}</label>
          <input class="login__input" id="phone" type="tel" autocomplete="tel" />
        </div>

        <div class="login__field">
          <label class="login__label" for="password">{t(lang, "register.password")}</label>
          <input class="login__input" id="password" type="password" required autocomplete="new-password" minlength="8" />
          <span class="account-form__hint">{t(lang, "register.passwordHint")}</span>
        </div>

        <div id="register-error" class="login__error"></div>

        <button class="login__submit" type="submit" id="register-btn">
          {t(lang, "register.submit")}
        </button>
      </form>

      <p class="login__register-link">
        {t(lang, "register.haveAccount")}
        <a href={`/${lang}/prihlasenie`}>{t(lang, "register.login")}</a>
      </p>
    </div>
  </main>

  <script id="register-config" type="application/json" set:html={JSON.stringify({
    apiBase,
    lang,
    submitLabel: t(lang, "register.submit"),
    submittingLabel: t(lang, "register.submitting"),
    passwordTooShort: t(lang, "register.passwordTooShort"),
    emailExists: t(lang, "register.emailExists"),
    accountUrl: `/${lang}/ucet`,
  })}></script>

  <script>
    import { syncLocalCartToServer } from "../../../lib/cart";
    import { updateProfile } from "../../../lib/account";

    const cfg = JSON.parse(document.getElementById("register-config")!.textContent!);
    const form = document.getElementById("register-form") as HTMLFormElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("register-btn") as HTMLButtonElement;
      const errEl = document.getElementById("register-error")!;
      const email = (document.getElementById("email") as HTMLInputElement).value.trim();
      const displayName = (document.getElementById("display-name") as HTMLInputElement).value.trim();
      const phone = (document.getElementById("phone") as HTMLInputElement).value.trim();
      const password = (document.getElementById("password") as HTMLInputElement).value;

      errEl.textContent = "";
      if (password.length < 8) {
        errEl.textContent = cfg.passwordTooShort;
        return;
      }

      btn.disabled = true;
      btn.textContent = cfg.submittingLabel;

      try {
        const res = await fetch(`${cfg.apiBase}/api/auth/register`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password, displayName }),
        });

        if (!res.ok) {
          if (res.status === 409) throw new Error(cfg.emailExists);
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || `Registration failed (${res.status})`);
        }

        const data = await res.json();
        localStorage.setItem("partlphoto_token", data.accessToken);
        localStorage.setItem("partlphoto_user", JSON.stringify({
          id: data.userId, email: data.email, role: data.role,
        }));

        // Persist phone if provided — endpoint exists already.
        if (phone) {
          try { await updateProfile({ phone }); } catch { /* non-fatal */ }
        }

        try { await syncLocalCartToServer(data.accessToken); } catch { /* ignore */ }

        const params = new URLSearchParams(window.location.search);
        const returnUrl = params.get("return") || cfg.accountUrl;
        window.location.href = returnUrl;
      } catch (err: any) {
        errEl.textContent = err.message;
        btn.disabled = false;
        btn.textContent = cfg.submitLabel;
      }
    });
  </script>
</BaseLayout>

<style lang="scss" is:global>
  @use "../../../styles/components/login";
  @use "../../../styles/components/account";
</style>
