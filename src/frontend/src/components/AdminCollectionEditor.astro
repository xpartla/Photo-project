---
import { t } from "../lib/i18n";

interface Props { lang: "sk" | "en"; mode: "create" | "edit"; slug?: string; }
const { lang, mode, slug } = Astro.props;
---

<div data-admin-root hidden>
  <header class="admin__header">
    <a href={`/${lang}/admin/portfolio/collections`} class="admin__back">← {t(lang, "admin.common.backToList")}</a>
    <h1 class="admin__title">
      {mode === "create" ? t(lang, "admin.portfolio.newCollection") : t(lang, "admin.common.edit")}
    </h1>
  </header>

  <form class="account-form" id="coll-form">
    <div class="account-form__row">
      <div class="account-form__field">
        <label class="account-form__label" for="name-sk">{t(lang, "admin.portfolio.collectionNameSk")} *</label>
        <input class="account-form__input" id="name-sk" type="text" required />
      </div>
      <div class="account-form__field">
        <label class="account-form__label" for="name-en">{t(lang, "admin.portfolio.collectionNameEn")} *</label>
        <input class="account-form__input" id="name-en" type="text" required />
      </div>
    </div>

    <div class="account-form__field">
      <label class="account-form__label" for="slug">{t(lang, "admin.portfolio.slug")} *</label>
      <input class="account-form__input" id="slug" type="text" pattern="[a-z0-9-]+" required />
    </div>

    <div class="account-form__row">
      <div class="account-form__field">
        <label class="account-form__label" for="desc-sk">{t(lang, "admin.portfolio.collectionDescSk")}</label>
        <textarea class="account-form__input" id="desc-sk" rows="2"></textarea>
      </div>
      <div class="account-form__field">
        <label class="account-form__label" for="desc-en">{t(lang, "admin.portfolio.collectionDescEn")}</label>
        <textarea class="account-form__input" id="desc-en" rows="2"></textarea>
      </div>
    </div>

    <div class="account-form__field">
      <label class="account-form__label">{t(lang, "admin.portfolio.photosInCollection")}</label>
      <div class="admin-photo-picker" id="photo-picker"></div>
    </div>

    <div id="coll-error" class="account-form__error"></div>
    <div id="coll-success" class="account-form__success"></div>

    <div class="account-form__actions">
      <button type="submit" class="account-form__submit" id="save-btn">{t(lang, "admin.common.save")}</button>
    </div>
  </form>
</div>

<p class="admin__notice" data-admin-denied hidden>{t(lang, "admin.notAuthorized")}</p>

<script id="coll-config" type="application/json" set:html={JSON.stringify({
  lang, mode, slug: slug ?? null,
  save: t(lang, "admin.common.save"),
  saving: t(lang, "admin.common.saving"),
  saved: t(lang, "admin.common.saved"),
  redirect: `/${lang}/admin/portfolio/collections`,
})}></script>

<script>
  import { requireAdmin } from "../lib/admin";
  import { getCollection, createCollection, updateCollection, listPhotos } from "../lib/admin-api";

  const cfg = JSON.parse(document.getElementById("coll-config")!.textContent!);
  const token = requireAdmin(cfg.lang);
  if (!token) throw new Error("not admin");

  const root = document.querySelector("[data-admin-root]") as HTMLElement;
  root.hidden = false;

  const errEl = document.getElementById("coll-error")!;
  const okEl = document.getElementById("coll-success")!;
  const btn = document.getElementById("save-btn") as HTMLButtonElement;
  const pickerEl = document.getElementById("photo-picker")!;

  let collectionId: string | null = null;
  const selectedPhotos = new Set<string>();

  function escapeHtml(s: string): string {
    return (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c]!));
  }
  function thumb(p: any): string {
    const v = (p.variants || []).find((x: any) => x.format === "jpeg" || x.format === "jpg") ?? p.variants?.[0];
    return v ? v.blobUrl.replace(/^http:\/\/azurite:10000\/devstoreaccount1/, "http://localhost:10000/devstoreaccount1") : "";
  }

  async function renderPicker() {
    const data = await listPhotos(cfg.lang, { size: 200, includeUnpublished: true });
    pickerEl.innerHTML = (data.items || []).map((p: any) => `
      <div class="admin-photo-picker__item ${selectedPhotos.has(p.id) ? "admin-photo-picker__item--selected" : ""}" data-photo-id="${escapeHtml(p.id)}" title="${escapeHtml(p.title || p.slug)}">
        <img src="${escapeHtml(thumb(p))}" alt="" loading="lazy" />
      </div>
    `).join("");
    pickerEl.querySelectorAll<HTMLElement>("[data-photo-id]").forEach((el) => {
      el.addEventListener("click", () => {
        const id = el.dataset.photoId!;
        if (selectedPhotos.has(id)) {
          selectedPhotos.delete(id);
          el.classList.remove("admin-photo-picker__item--selected");
        } else {
          selectedPhotos.add(id);
          el.classList.add("admin-photo-picker__item--selected");
        }
      });
    });
  }

  (async () => {
    if (cfg.mode === "edit" && cfg.slug) {
      try {
        const detail: any = await getCollection(cfg.slug, cfg.lang);
        collectionId = detail.id;
        (document.getElementById("name-sk") as HTMLInputElement).value = detail.nameSk ?? "";
        (document.getElementById("name-en") as HTMLInputElement).value = detail.nameEn ?? "";
        (document.getElementById("slug") as HTMLInputElement).value = detail.slug ?? "";
        (document.getElementById("desc-sk") as HTMLTextAreaElement).value = detail.descriptionSk ?? "";
        (document.getElementById("desc-en") as HTMLTextAreaElement).value = detail.descriptionEn ?? "";
        (detail.photos?.items || []).forEach((p: any) => selectedPhotos.add(p.id));
      } catch (err: any) {
        errEl.textContent = err.message;
      }
    }
    await renderPicker();
  })();

  document.getElementById("coll-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl.textContent = "";
    okEl.textContent = "";
    btn.disabled = true;
    btn.textContent = cfg.saving;

    const input = {
      slug: (document.getElementById("slug") as HTMLInputElement).value.trim(),
      nameSk: (document.getElementById("name-sk") as HTMLInputElement).value.trim(),
      nameEn: (document.getElementById("name-en") as HTMLInputElement).value.trim(),
      descriptionSk: (document.getElementById("desc-sk") as HTMLTextAreaElement).value || null,
      descriptionEn: (document.getElementById("desc-en") as HTMLTextAreaElement).value || null,
      photoIds: Array.from(selectedPhotos),
    };

    try {
      if (cfg.mode === "create") {
        await createCollection(input);
      } else if (collectionId) {
        await updateCollection(collectionId, input);
      }
      window.location.href = cfg.redirect;
    } catch (err: any) {
      errEl.textContent = err.message;
      btn.disabled = false;
      btn.textContent = cfg.save;
    }
  });
</script>
