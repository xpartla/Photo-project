---
import { t } from "../lib/i18n";

interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const leftLinks = [
  { href: `/${lang === "sk" ? "sk/obchod" : "en/shop"}`, label: t(lang, "nav.shop") },
  { href: `/${lang === "sk" ? "sk/rezervacia" : "en/booking"}`, label: t(lang, "nav.booking") },
  { href: `/${lang}/portfolio`, label: t(lang, "nav.portfolio") },
];

const rightLinks = [
  { href: `/${lang}/blog`, label: t(lang, "nav.blog") },
  { href: `/${lang === "sk" ? "sk/kontakt" : "en/contact"}`, label: t(lang, "nav.contact") },
];

const langSwitchHref = lang === "sk" ? "/en" : "/sk";
const langSwitchLabel = lang === "sk" ? "EN" : "SK";
---

<nav class="navbar" data-navbar>
  <div class="navbar__inner">
    <!-- Left links -->
    <ul class="navbar__links navbar__links--left">
      {leftLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Brand -->
    <a href={`/${lang}`} class="navbar__brand">
      PartlPhoto
    </a>

    <!-- Right links -->
    <ul class="navbar__links navbar__links--right">
      {rightLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}

      <!-- Auth: Login / Account dropdown -->
      <li class="navbar__auth" data-auth-container>
        <!-- Logged-out state (default) -->
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__login-btn" data-login-btn>
          {t(lang, "nav.login")}
        </a>

        <!-- Logged-in state (hidden by default, toggled via JS) -->
        <div class="navbar__account" data-account-menu hidden>
          <button class="navbar__account-toggle" data-account-toggle aria-expanded="false" aria-haspopup="true">
            <svg class="navbar__account-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
          </button>
          <div class="navbar__dropdown" data-dropdown>
            <a href={`/${lang === "sk" ? "sk/kosik" : "en/cart"}`} class="navbar__dropdown-item">
              {t(lang, "nav.cart")}
            </a>
            <a href={`/${lang === "sk" ? "sk/ucet" : "en/account"}`} class="navbar__dropdown-item">
              {t(lang, "nav.account")}
            </a>
            <hr class="navbar__dropdown-divider" />
            <button class="navbar__dropdown-item navbar__dropdown-item--logout" data-logout-btn>
              {t(lang, "nav.logout")}
            </button>
          </div>
        </div>
      </li>

      <!-- Language switch -->
      <li>
        <a href={langSwitchHref} class="navbar__lang-btn">
          {langSwitchLabel}
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button class="navbar__hamburger" data-hamburger aria-label="Menu" aria-expanded="false">
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" data-mobile-menu hidden>
    <ul class="navbar__mobile-links">
      {leftLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      {rightLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      <li data-mobile-auth>
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__mobile-link" data-mobile-login-btn>
          {t(lang, "nav.login")}
        </a>
      </li>
      <li>
        <a href={langSwitchHref} class="navbar__mobile-link navbar__mobile-link--lang">
          {langSwitchLabel}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  function initNavbar() {
    const navbar = document.querySelector("[data-navbar]");
    if (!navbar) return;

    // Account dropdown toggle
    const accountToggle = navbar.querySelector("[data-account-toggle]") as HTMLButtonElement | null;
    const dropdown = navbar.querySelector("[data-dropdown]");

    if (accountToggle && dropdown) {
      accountToggle.addEventListener("click", () => {
        const expanded = accountToggle.getAttribute("aria-expanded") === "true";
        accountToggle.setAttribute("aria-expanded", String(!expanded));
        dropdown.classList.toggle("navbar__dropdown--open");
      });

      document.addEventListener("click", (e) => {
        if (!accountToggle.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
          accountToggle.setAttribute("aria-expanded", "false");
          dropdown.classList.remove("navbar__dropdown--open");
        }
      });
    }

    // Mobile menu toggle
    const hamburger = navbar.querySelector("[data-hamburger]") as HTMLButtonElement | null;
    const mobileMenu = navbar.querySelector("[data-mobile-menu]") as HTMLElement | null;

    if (hamburger && mobileMenu) {
      hamburger.addEventListener("click", () => {
        const expanded = hamburger.getAttribute("aria-expanded") === "true";
        hamburger.setAttribute("aria-expanded", String(!expanded));
        hamburger.classList.toggle("navbar__hamburger--open");
        mobileMenu.hidden = !mobileMenu.hidden;
        mobileMenu.classList.toggle("navbar__mobile-menu--open");
      });
    }
  }

  initNavbar();
  document.addEventListener("astro:after-swap", initNavbar);
</script>

<style lang="scss">
  @use "../styles/components/navbar";
</style>
