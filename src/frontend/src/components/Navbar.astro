---
import { t } from "../lib/i18n";

interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const leftLinks = [
  { href: `/${lang === "sk" ? "sk/obchod" : "en/shop"}`, label: t(lang, "nav.shop") },
  { href: `/${lang === "sk" ? "sk/rezervacia" : "en/booking"}`, label: t(lang, "nav.booking") },
  { href: `/${lang}/portfolio`, label: t(lang, "nav.portfolio") },
];

const rightLinks = [
  { href: `/${lang}/blog`, label: t(lang, "nav.blog") },
  { href: `/${lang === "sk" ? "sk/kontakt" : "en/contact"}`, label: t(lang, "nav.contact") },
];

const langSwitchHref = lang === "sk" ? "/en" : "/sk";
const langSwitchLabel = lang === "sk" ? "EN" : "SK";
---

<nav class="navbar" data-navbar>
  <div class="navbar__inner">
    <!-- Left links -->
    <ul class="navbar__links navbar__links--left">
      {leftLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Brand -->
    <a href={`/${lang}`} class="navbar__brand">
      PartlPhoto
    </a>

    <!-- Right links -->
    <ul class="navbar__links navbar__links--right">
      {rightLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}

      <!-- Auth: Login / Account dropdown -->
      <li class="navbar__auth" data-auth-container>
        <!-- Logged-out state (default) -->
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__login-btn" data-login-btn>
          {t(lang, "nav.login")}
        </a>

        <!-- Logged-in state (hidden by default, toggled via JS) -->
        <div class="navbar__account" data-account-menu hidden>
          <button class="navbar__account-toggle" data-account-toggle aria-expanded="false" aria-haspopup="true">
            <svg class="navbar__account-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
          </button>
          <div class="navbar__dropdown" data-dropdown>
            <a href={`/${lang === "sk" ? "sk/kosik" : "en/cart"}`} class="navbar__dropdown-item">
              {t(lang, "nav.cart")}
            </a>
            <a href={`/${lang === "sk" ? "sk/ucet" : "en/account"}`} class="navbar__dropdown-item">
              {t(lang, "nav.account")}
            </a>
            <hr class="navbar__dropdown-divider" />
            <button class="navbar__dropdown-item navbar__dropdown-item--logout" data-logout-btn>
              {t(lang, "nav.logout")}
            </button>
          </div>
        </div>
      </li>

      <!-- Language switch -->
      <li>
        <a href={langSwitchHref} class="navbar__lang-btn">
          {langSwitchLabel}
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button class="navbar__hamburger" data-hamburger aria-label="Menu" aria-expanded="false">
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" data-mobile-menu hidden>
    <ul class="navbar__mobile-links">
      {leftLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      {rightLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      <li data-mobile-auth>
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__mobile-link" data-mobile-login-btn>
          {t(lang, "nav.login")}
        </a>
      </li>
      <li>
        <a href={langSwitchHref} class="navbar__mobile-link navbar__mobile-link--lang">
          {langSwitchLabel}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  function initNavbar() {
    const navbar = document.querySelector("[data-navbar]");
    if (!navbar) return;

    // Account dropdown toggle
    const accountToggle = navbar.querySelector("[data-account-toggle]") as HTMLButtonElement | null;
    const dropdown = navbar.querySelector("[data-dropdown]");

    if (accountToggle && dropdown) {
      accountToggle.addEventListener("click", () => {
        const expanded = accountToggle.getAttribute("aria-expanded") === "true";
        accountToggle.setAttribute("aria-expanded", String(!expanded));
        dropdown.classList.toggle("navbar__dropdown--open");
      });

      document.addEventListener("click", (e) => {
        if (!accountToggle.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
          accountToggle.setAttribute("aria-expanded", "false");
          dropdown.classList.remove("navbar__dropdown--open");
        }
      });
    }

    // Mobile menu toggle
    const hamburger = navbar.querySelector("[data-hamburger]") as HTMLButtonElement | null;
    const mobileMenu = navbar.querySelector("[data-mobile-menu]") as HTMLElement | null;

    if (hamburger && mobileMenu) {
      hamburger.addEventListener("click", () => {
        const expanded = hamburger.getAttribute("aria-expanded") === "true";
        hamburger.setAttribute("aria-expanded", String(!expanded));
        hamburger.classList.toggle("navbar__hamburger--open");
        mobileMenu.hidden = !mobileMenu.hidden;
        mobileMenu.classList.toggle("navbar__mobile-menu--open");
      });
    }
  }

  initNavbar();
  document.addEventListener("astro:after-swap", initNavbar);
</script>

<style lang="scss">
  @use "sass:color";
  @use "../styles/variables" as *;

  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: $white;
    border-bottom: $outline-width solid $outline;
    height: $nav-height;

    &__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px;
      height: 100%;
    }

    // ── Brand ─────────────────────────────
    &__brand {
      font-family: $font-heading;
      font-size: 1.75rem;
      color: $dark;
      letter-spacing: 0.5px;
      transition: color $transition-base;
      flex-shrink: 0;

      &:hover {
        color: $blue;
      }
    }

    // ── Links ─────────────────────────────
    &__links {
      display: flex;
      align-items: center;
      gap: 8px;

      &--left {
        flex: 1;
        justify-content: flex-end;
        padding-right: 32px;
      }

      &--right {
        flex: 1;
        justify-content: flex-start;
        padding-left: 32px;
      }
    }

    &__link {
      font-family: $font-body;
      font-weight: 700;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 6px 14px;
      border-radius: 8px;
      border: $outline-width solid transparent;
      transition: all $transition-base;

      &:hover {
        border-color: $outline;
        background-color: $yellow;
      }

      &--active {
        border-color: $outline;
        background-color: $yellow;
      }
    }

    // ── Login button ──────────────────────
    &__login-btn {
      font-family: $font-body;
      font-weight: 700;
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 6px 18px;
      border-radius: 8px;
      border: $outline-width solid $outline;
      background-color: $blue;
      color: $white;
      transition: all $transition-base;

      &:hover {
        background-color: color.adjust($blue, $lightness: -8%);
        transform: translateY(-1px);
      }
    }

    // ── Language button ───────────────────
    &__lang-btn {
      font-family: $font-body;
      font-weight: 800;
      font-size: 0.85rem;
      padding: 4px 10px;
      border-radius: 6px;
      border: 2px solid $outline;
      background-color: $cream;
      transition: all $transition-fast;

      &:hover {
        background-color: $orange;
      }
    }

    // ── Account dropdown ──────────────────
    &__auth {
      position: relative;
    }

    &__account {
      position: relative;
    }

    &__account-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: $outline-width solid $outline;
      background-color: $yellow;
      color: $dark;
      transition: all $transition-base;

      &:hover {
        background-color: color.adjust($yellow, $lightness: -8%);
        transform: translateY(-1px);
      }
    }

    &__account-icon {
      width: 22px;
      height: 22px;
    }

    &__dropdown {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      min-width: 180px;
      background-color: $white;
      border: $outline-width solid $outline;
      border-radius: 12px;
      padding: 8px 0;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all $transition-base;
      box-shadow: 4px 4px 0 $outline;

      &--open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
    }

    &__dropdown-item {
      display: block;
      width: 100%;
      text-align: left;
      padding: 10px 20px;
      font-family: $font-body;
      font-weight: 600;
      font-size: 0.9rem;
      color: $dark;
      transition: background-color $transition-fast;

      &:hover {
        background-color: $cream;
      }

      &--logout {
        color: $red;
      }
    }

    &__dropdown-divider {
      border: none;
      border-top: 2px solid color.adjust($dark, $lightness: 70%);
      margin: 4px 16px;
    }

    // ── Hamburger (mobile) ────────────────
    &__hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 36px;
      height: 36px;
      padding: 4px;

      @media (max-width: $breakpoint-md) {
        display: flex;
      }
    }

    &__hamburger-line {
      display: block;
      width: 100%;
      height: 3px;
      background-color: $dark;
      border-radius: 2px;
      transition: all $transition-base;
    }

    &__hamburger--open {
      .navbar__hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(5px, 6px);
      }
      .navbar__hamburger-line:nth-child(2) {
        opacity: 0;
      }
      .navbar__hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(5px, -6px);
      }
    }

    // ── Mobile menu ───────────────────────
    &__mobile-menu {
      display: none;
      position: absolute;
      top: $nav-height;
      left: 0;
      right: 0;
      background-color: $white;
      border-bottom: $outline-width solid $outline;
      padding: 16px 24px 24px;

      &--open {
        display: block;
        animation: slideDown 250ms ease forwards;
      }
    }

    &__mobile-links {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    &__mobile-link {
      display: block;
      font-family: $font-body;
      font-weight: 700;
      font-size: 1.1rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 16px;
      border-radius: 10px;
      border: $outline-width solid transparent;
      transition: all $transition-fast;

      &:hover, &--active {
        border-color: $outline;
        background-color: $yellow;
      }

      &--lang {
        text-align: center;
        margin-top: 8px;
        background-color: $cream;
        border-color: $outline;

        &:hover {
          background-color: $orange;
        }
      }
    }

    // ── Desktop: hide hamburger / mobile menu ──
    @media (max-width: $breakpoint-md) {
      &__links {
        display: none;
      }
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
