---
import { t } from "../lib/i18n";

interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const leftLinks = [
  { href: `/${lang === "sk" ? "sk/obchod" : "en/shop"}`, label: t(lang, "nav.shop") },
  { href: `/${lang === "sk" ? "sk/rezervacia" : "en/booking"}`, label: t(lang, "nav.booking") },
  { href: `/${lang}/portfolio`, label: t(lang, "nav.portfolio") },
];

const rightLinks = [
  { href: `/${lang}/blog`, label: t(lang, "nav.blog") },
  { href: `/${lang === "sk" ? "sk/kontakt" : "en/contact"}`, label: t(lang, "nav.contact") },
];

const langSwitchHref = lang === "sk" ? "/en" : "/sk";
const langSwitchLabel = lang === "sk" ? "EN" : "SK";
---

<nav class="navbar" data-navbar>
  <div class="navbar__inner">
    <!-- Left links -->
    <ul class="navbar__links navbar__links--left">
      {leftLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Brand -->
    <a href={`/${lang}`} class="navbar__brand">
      PartlPhoto
    </a>

    <!-- Right links -->
    <ul class="navbar__links navbar__links--right">
      {rightLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["navbar__link", { "navbar__link--active": currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}

      <!-- Language switch -->
      <li>
        <a href={langSwitchHref} class="navbar__lang-btn">
          {langSwitchLabel}
        </a>
      </li>

      <!-- Auth: Login / Account dropdown -->
      <li class="navbar__auth" data-auth-container>
        <!-- Logged-out state (default) -->
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__login-btn" data-login-btn>
          {t(lang, "nav.login")}
        </a>

        <!-- Logged-in state (hidden by default, toggled via JS) -->
        <div class="navbar__account" data-account-menu hidden>
          <button class="navbar__account-toggle" data-account-toggle aria-expanded="false" aria-haspopup="true">
            <svg class="navbar__account-icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
          </button>
          <div class="navbar__dropdown" data-dropdown>
            <a href={`/${lang === "sk" ? "sk/obchod/objednavky" : "en/shop/orders"}`} class="navbar__dropdown-item">
              {t(lang, "order.myOrders")}
            </a>
            <hr class="navbar__dropdown-divider" />
            <button class="navbar__dropdown-item navbar__dropdown-item--logout" data-logout-btn>
              {t(lang, "nav.logout")}
            </button>
          </div>
        </div>
      </li>

      <!-- Cart icon with badge (always visible) -->
      <li>
        <a href={`/${lang === "sk" ? "sk/obchod/kosik" : "en/shop/cart"}`} class="navbar__cart-btn" data-cart-link>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
          </svg>
          <span class="navbar__cart-badge" id="cart-count-badge" data-cart-badge style="display:none;">0</span>
        </a>
      </li>
    </ul>

    <!-- Mobile-only action bar: cart + account always reachable without opening the menu. -->
    <div class="navbar__mobile-actions">
      <a
        href={`/${lang === "sk" ? "sk/obchod/kosik" : "en/shop/cart"}`}
        class="navbar__mobile-cart"
        data-cart-link
        aria-label={t(lang, "nav.cart")}
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" />
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
        </svg>
        <span class="navbar__cart-badge" data-cart-badge style="display:none;">0</span>
      </a>

      <a
        href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`}
        class="navbar__mobile-account"
        data-mobile-account
        aria-label={t(lang, "nav.login")}
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="navbar__hamburger" data-hamburger aria-label="Menu" aria-expanded="false">
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
      <span class="navbar__hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="navbar__mobile-menu" data-mobile-menu hidden>
    <ul class="navbar__mobile-links">
      {leftLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      {rightLinks.map((link) => (
        <li>
          <a href={link.href} class:list={["navbar__mobile-link", { "navbar__mobile-link--active": currentPath.startsWith(link.href) }]}>
            {link.label}
          </a>
        </li>
      ))}
      <li data-mobile-auth>
        <a href={`/${lang === "sk" ? "sk/prihlasenie" : "en/login"}`} class="navbar__mobile-link" data-mobile-login-btn>
          {t(lang, "nav.login")}
        </a>
      </li>
      <li>
        <a href={langSwitchHref} class="navbar__mobile-link navbar__mobile-link--lang">
          {langSwitchLabel}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  import { getCartCount } from "../lib/cart";

  async function refreshCartBadge() {
    const badges = document.querySelectorAll<HTMLElement>("[data-cart-badge]");
    const cartLinks = document.querySelectorAll<HTMLElement>("[data-cart-link]");
    if (badges.length === 0) return;
    try {
      const count = await getCartCount();
      badges.forEach((b) => {
        b.textContent = String(count);
        b.style.display = count > 0 ? "" : "none";
      });
      // Toggle an "active" state on cart buttons so the mobile icon draws
      // attention when there's something to check out.
      cartLinks.forEach((a) => a.classList.toggle("navbar__cart-btn--active", count > 0));
    } catch {
      badges.forEach((b) => (b.style.display = "none"));
    }
  }

  function initNavbar() {
    const navbar = document.querySelector("[data-navbar]") as HTMLElement | null;
    if (!navbar) return;

    // ── Auth state ──────────────────────────────────────────────
    const token = localStorage.getItem("partlphoto_token");
    const loginBtn = navbar.querySelector("[data-login-btn]") as HTMLElement | null;
    const accountMenu = navbar.querySelector("[data-account-menu]") as HTMLElement | null;
    const mobileLoginBtn = navbar.querySelector("[data-mobile-login-btn]") as HTMLElement | null;

    // Mobile account icon redirects straight to "my orders" when logged in
    // (no dropdown on mobile) — otherwise to the login page.
    const mobileAccount = navbar.querySelector("[data-mobile-account]") as HTMLAnchorElement | null;
    const lang = document.documentElement.lang === "sk" ? "sk" : "en";
    const ordersHref = lang === "sk" ? "/sk/obchod/objednavky" : "/en/shop/orders";
    const loginHref = lang === "sk" ? "/sk/prihlasenie" : "/en/login";

    if (token) {
      if (loginBtn) loginBtn.style.display = "none";
      if (accountMenu) accountMenu.hidden = false;
      if (mobileLoginBtn) mobileLoginBtn.textContent = "Account";
      if (mobileAccount) mobileAccount.href = ordersHref;
    } else {
      if (loginBtn) loginBtn.style.display = "";
      if (accountMenu) accountMenu.hidden = true;
      if (mobileAccount) mobileAccount.href = loginHref;
    }

    // ── Cart badge ──────────────────────────────────────────────
    refreshCartBadge();
    window.addEventListener("cart:changed", refreshCartBadge);

    // ── Account dropdown toggle ─────────────────────────────────
    const accountToggle = navbar.querySelector("[data-account-toggle]");
    const dropdown = navbar.querySelector("[data-dropdown]");

    if (accountToggle && dropdown) {
      accountToggle.addEventListener("click", function() {
        const expanded = accountToggle.getAttribute("aria-expanded") === "true";
        accountToggle.setAttribute("aria-expanded", String(!expanded));
        dropdown.classList.toggle("navbar__dropdown--open");
      });

      document.addEventListener("click", function(e) {
        if (!accountToggle.contains(e.target) && !dropdown.contains(e.target)) {
          accountToggle.setAttribute("aria-expanded", "false");
          dropdown.classList.remove("navbar__dropdown--open");
        }
      });
    }

    // ── Logout ──────────────────────────────────────────────────
    const logoutBtn = navbar.querySelector("[data-logout-btn]");
    if (logoutBtn) {
      logoutBtn.addEventListener("click", function() {
        localStorage.removeItem("partlphoto_token");
        localStorage.removeItem("partlphoto_user");
        window.location.reload();
      });
    }

    // ── Mobile menu toggle ──────────────────────────────────────
    const hamburger = navbar.querySelector("[data-hamburger]");
    const mobileMenu = navbar.querySelector("[data-mobile-menu]");

    if (hamburger && mobileMenu) {
      hamburger.addEventListener("click", function() {
        const expanded = hamburger.getAttribute("aria-expanded") === "true";
        hamburger.setAttribute("aria-expanded", String(!expanded));
        hamburger.classList.toggle("navbar__hamburger--open");
        mobileMenu.hidden = !mobileMenu.hidden;
        mobileMenu.classList.toggle("navbar__mobile-menu--open");
      });
    }
  }

  initNavbar();
  document.addEventListener("astro:after-swap", initNavbar);
</script>

<style lang="scss">
  @use "../styles/components/navbar";
</style>
