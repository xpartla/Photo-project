---
import PhotoStrip from "./PhotoStrip.astro";
import type { PhotoSummary } from "../lib/api";

interface Props {
  lang: string;
  dogPhotos: PhotoSummary[];
  filmPhotos: PhotoSummary[];
  labels: {
    tagline: string;
    subtitle: string;
    ctaPortfolio: string;
    ctaBooking: string;
    dogPhotos: string;
    filmPhotos: string;
    shopLinkText: string;
    ctaBanner: string;
    ctaBannerSub: string;
    ctaBookNow: string;
  };
}

const { lang, dogPhotos, filmPhotos, labels } = Astro.props;

const bookingHref = lang === "sk" ? `/${lang}/rezervacia` : `/${lang}/booking`;
const portfolioHref = `/${lang}/portfolio`;
const hasDog = dogPhotos.length > 0;
const hasFilm = filmPhotos.length > 0;
---

<!-- ── Hero ───────────────────────────────────────────── -->
<section class="hero">
  <!-- Background decorations -->
  <div class="hero__deco" aria-hidden="true">
    <!-- Sparkle stars — one in each accent color -->
    <svg class="hero__sparkle hero__sparkle--1" viewBox="0 0 24 24">
      <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#F2B880" />
    </svg>
    <svg class="hero__sparkle hero__sparkle--2" viewBox="0 0 24 24">
      <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#B8A0C8" />
    </svg>
    <svg class="hero__sparkle hero__sparkle--3" viewBox="0 0 24 24">
      <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#D97B8F" />
    </svg>
    <svg class="hero__sparkle hero__sparkle--4" viewBox="0 0 24 24">
      <path d="M12 0 L14 10 L24 12 L14 14 L12 24 L10 14 L0 12 L10 10 Z" fill="#D4896A" />
    </svg>

    <!-- Dashed circles -->
    <svg class="hero__circle hero__circle--1" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="45" stroke="#F2B880" stroke-width="3" fill="none" stroke-dasharray="8 6" />
    </svg>
    <svg class="hero__circle hero__circle--2" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="45" stroke="#B8A0C8" stroke-width="3" fill="none" stroke-dasharray="8 6" />
    </svg>
  </div>

  <div class="hero__content">
    <h1 class="hero__brand">PartlPhoto</h1>
    <svg class="hero__underline" viewBox="0 0 300 12" fill="none" aria-hidden="true">
      <path
        d="M0 6 Q25 0 50 6 Q75 12 100 6 Q125 0 150 6 Q175 12 200 6 Q225 0 250 6 Q275 12 300 6"
        stroke="#F2B880"
        stroke-width="4"
        stroke-linecap="round"
      />
    </svg>
    <p class="hero__tagline">{labels.tagline}</p>
    <p class="hero__subtitle">{labels.subtitle}</p>
    <div class="hero__ctas">
      <a href={portfolioHref} class="hero__btn hero__btn--primary">
        {labels.ctaPortfolio}
      </a>
      <a href={bookingHref} class="hero__btn hero__btn--secondary">
        {labels.ctaBooking}
      </a>
    </div>
  </div>

  <!-- Bottom gradient divider -->
  <div class="hero__divider" aria-hidden="true"></div>
</section>

<!-- ── Photo Strips ──────────────────────────────────── -->
<div class="home-strips">
  {hasDog && (
    <PhotoStrip
      photos={dogPhotos}
      label={labels.dogPhotos}
      lang={lang}
      shopLinkText={labels.shopLinkText}
      accent="#F2B880"
    />
  )}

  {hasDog && hasFilm && (
    <div class="section-ornament" data-reveal-section aria-hidden="true">
      <svg viewBox="0 0 200 24">
        <line x1="20" y1="12" x2="90" y2="12" stroke="#2A2A2A" stroke-width="2.5" stroke-linecap="round" />
        <path d="M100 2 L108 12 L100 22 L92 12 Z" fill="#D4896A" stroke="#2A2A2A" stroke-width="2" />
        <line x1="110" y1="12" x2="180" y2="12" stroke="#2A2A2A" stroke-width="2.5" stroke-linecap="round" />
      </svg>
    </div>
  )}

  {hasFilm && (
    <PhotoStrip
      photos={filmPhotos}
      label={labels.filmPhotos}
      lang={lang}
      shopLinkText={labels.shopLinkText}
      accent="#B8A0C8"
    />
  )}
</div>

<!-- ── CTA Banner ────────────────────────────────────── -->
<section class="cta-banner" data-reveal-section>
  <div class="cta-banner__content">
    <h2 class="cta-banner__heading">{labels.ctaBanner}</h2>
    <p class="cta-banner__sub">{labels.ctaBannerSub}</p>
    <a href={bookingHref} class="cta-banner__btn">
      {labels.ctaBookNow}
    </a>
  </div>
</section>

<style lang="scss">
  @use "sass:color";
  @use "../styles/variables" as *;

  // ── Keyframes ─────────────────────────────────────────
  @keyframes dropIn {
    0% { transform: translateY(-30px); opacity: 0; }
    60% { transform: translateY(4px); opacity: 1; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes drawLine {
    from { stroke-dashoffset: 320; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes twinkle {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.7; }
    50% { transform: scale(1.3) rotate(20deg); opacity: 1; }
  }

  @keyframes gentleSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  // ── Hero ──────────────────────────────────────────────
  .hero {
    min-height: calc(85vh - #{$nav-height});
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 3rem 2rem 4rem;
  }

  .hero__deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__sparkle {
    position: absolute;

    &--1 { top: 18%; left: 12%; width: 32px; animation: twinkle 3s ease-in-out infinite; }
    &--2 { top: 14%; right: 10%; width: 26px; animation: twinkle 3s ease-in-out 0.7s infinite; }
    &--3 { bottom: 24%; left: 8%; width: 22px; animation: twinkle 3s ease-in-out 1.4s infinite; }
    &--4 { bottom: 30%; right: 14%; width: 28px; animation: twinkle 3s ease-in-out 0.3s infinite; }
  }

  .hero__circle {
    position: absolute;
    opacity: 0.12;

    &--1 { top: -5%; left: -4%; width: 220px; animation: gentleSpin 40s linear infinite; }
    &--2 { bottom: -8%; right: -3%; width: 180px; animation: gentleSpin 35s linear infinite reverse; }
  }

  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 700px;
  }

  .hero__brand {
    font-family: $font-heading;
    font-size: 5rem;
    color: $dark;
    margin: 0;
    animation: dropIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .hero__underline {
    display: block;
    width: 260px;
    height: 14px;
    margin: -4px auto 0;

    path {
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1s ease 0.3s forwards;
    }
  }

  .hero__tagline {
    font-family: $font-heading;
    font-size: 1.6rem;
    color: $dark;
    margin-top: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.6s forwards;
  }

  .hero__subtitle {
    font-family: $font-body;
    font-weight: 600;
    font-size: 1.15rem;
    color: $dark;
    margin-top: 0.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.8s forwards;
  }

  .hero__ctas {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    margin-top: 2.25rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 1s forwards;
  }

  .hero__btn {
    font-family: $font-body;
    font-weight: 800;
    font-size: 1.05rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 0.75rem 1.8rem;
    border: $outline-width-thick solid $outline;
    border-radius: 10px;
    box-shadow: 4px 4px 0 $outline;
    text-decoration: none;
    transition:
      transform $transition-fast,
      box-shadow $transition-fast,
      background $transition-fast;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 5px 6px 0 $outline;
    }

    &:active {
      transform: translateY(1px);
      box-shadow: 2px 2px 0 $outline;
    }

    &:focus-visible {
      outline: 3px solid $sage;
      outline-offset: 3px;
    }

    &--primary {
      background: $peach;
      color: $dark;

      &:hover { background: color.adjust($peach, $lightness: -5%); }
    }

    &--secondary {
      background: $sage;
      color: $white;

      &:hover { background: color.adjust($sage, $lightness: -8%); }
    }
  }

  .hero__divider {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 500px;
    height: 3px;
    background: linear-gradient(to right, transparent, $peach, $lavender, transparent);
    border-radius: 2px;
  }

  // ── Strips Wrapper ────────────────────────────────────
  .home-strips {
    padding: 1rem 0 2rem;
  }

  // ── Section Ornament ──────────────────────────────────
  .section-ornament {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;

    &.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    svg {
      width: 180px;
      height: 24px;
    }
  }

  // ── CTA Banner ────────────────────────────────────────
  .cta-banner {
    background: $peach;
    border-top: $outline-width-thick solid $outline;
    border-bottom: $outline-width-thick solid $outline;
    text-align: center;
    padding: 3.5rem 2rem;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;

    &.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    // Vintage diagonal stripes
    &::before {
      content: "";
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 12px,
        rgba($dark, 0.03) 12px,
        rgba($dark, 0.03) 24px
      );
      pointer-events: none;
    }
  }

  .cta-banner__content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-banner__heading {
    font-family: $font-heading;
    font-size: 2rem;
    color: $dark;
    margin: 0 0 0.5rem;
  }

  .cta-banner__sub {
    font-family: $font-body;
    font-weight: 600;
    font-size: 1.05rem;
    color: $dark;
    margin: 0 0 1.75rem;
  }

  .cta-banner__btn {
    display: inline-block;
    font-family: $font-body;
    font-weight: 800;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    padding: 0.8rem 2.5rem;
    background: $sage;
    color: $white;
    border: $outline-width-thick solid $outline;
    border-radius: 10px;
    box-shadow: 4px 4px 0 $outline;
    text-decoration: none;
    transition:
      transform $transition-fast,
      box-shadow $transition-fast,
      background $transition-fast;

    &:hover {
      transform: translateY(-3px);
      box-shadow: 5px 6px 0 $outline;
      background: color.adjust($sage, $lightness: -8%);
    }

    &:active {
      transform: translateY(1px);
      box-shadow: 2px 2px 0 $outline;
    }

    &:focus-visible {
      outline: 3px solid $dark;
      outline-offset: 3px;
    }
  }

  // ── Responsive: Large desktop (1440+) ─────────────────
  @media (min-width: 1440px) {
    .hero__brand {
      font-size: 5.5rem;
    }

    .hero__tagline {
      font-size: 1.8rem;
    }

    .hero__underline {
      width: 300px;
    }

    .hero__btn {
      font-size: 1.1rem;
      padding: 0.85rem 2.2rem;
    }
  }

  // ── Responsive: Tablet ────────────────────────────────
  @media (max-width: $breakpoint-lg) {
    .hero__brand {
      font-size: 3.5rem;
    }

    .hero__tagline {
      font-size: 1.3rem;
    }

    .hero__underline {
      width: 200px;
    }

    .cta-banner__heading {
      font-size: 1.6rem;
    }
  }

  // ── Responsive: Mobile ────────────────────────────────
  @media (max-width: $breakpoint-md) {
    .hero {
      min-height: calc(70vh - #{$nav-height});
      padding: 2rem 1.25rem 3rem;
    }

    .hero__brand {
      font-size: 2.5rem;
    }

    .hero__tagline {
      font-size: 1.1rem;
      margin-top: 1rem;
    }

    .hero__subtitle {
      font-size: 1rem;
    }

    .hero__underline {
      width: 160px;
      height: 10px;
    }

    .hero__ctas {
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .hero__btn {
      width: 100%;
      max-width: 280px;
      text-align: center;
    }

    .hero__sparkle {
      &--1 { width: 22px; }
      &--2 { width: 18px; }
      &--3 { width: 16px; }
      &--4 { width: 20px; }
    }

    .hero__circle {
      &--1 { width: 140px; }
      &--2 { width: 110px; }
    }

    .hero__divider {
      width: 80%;
    }

    .home-strips {
      padding: 0.5rem 0 1rem;
    }

    .section-ornament svg {
      width: 140px;
    }

    .cta-banner {
      padding: 2.5rem 1.25rem;
    }

    .cta-banner__heading {
      font-size: 1.4rem;
    }

    .cta-banner__sub {
      font-size: 0.95rem;
    }

    .cta-banner__btn {
      font-size: 0.95rem;
      padding: 0.7rem 2rem;
    }
  }

  // ── Responsive: Small mobile ──────────────────────────
  @media (max-width: $breakpoint-sm) {
    .hero__brand {
      font-size: 2rem;
    }

    .hero__underline {
      width: 130px;
    }

    .hero__tagline {
      font-size: 1rem;
    }
  }

  // ── Reduced motion ────────────────────────────────────
  @media (prefers-reduced-motion: reduce) {
    .hero__brand,
    .hero__tagline,
    .hero__subtitle,
    .hero__ctas {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero__underline path {
      animation: none;
      stroke-dashoffset: 0;
    }

    .hero__sparkle {
      animation: none;
      opacity: 0.7;
    }

    .hero__circle {
      animation: none;
    }

    .section-ornament,
    .cta-banner {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  function initHomeAnimations() {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document
      .querySelectorAll<HTMLElement>("[data-reveal-section]")
      .forEach((el) => {
        if (prefersReduced) {
          el.classList.add("revealed");
        } else {
          observer.observe(el);
        }
      });
  }

  initHomeAnimations();
  document.addEventListener("astro:after-swap", initHomeAnimations);
</script>
