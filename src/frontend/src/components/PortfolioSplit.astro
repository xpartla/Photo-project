---
import ResponsiveImage from "./ResponsiveImage.astro";
import { buildSrcset, getFallbackUrl } from "../lib/imageUrl";
import type { PhotoSummary } from "../lib/api";

interface Props {
  lang: string;
  dogPhotos: PhotoSummary[];
  filmPhotos: PhotoSummary[];
  labels: {
    title: string;
    subtitle: string;
    dogSection: string;
    filmSection: string;
    viewDetail: string;
    buyAsPrint: string;
    close: string;
    noPhotos: string;
  };
}

const { lang, dogPhotos, filmPhotos, labels } = Astro.props;

const rotations = [-2, 1.5, -1, 2.5, -0.5, 1, -1.5, 0.5, -2.5, 1.8];

function photoData(photo: PhotoSummary) {
  return JSON.stringify({
    slug: photo.slug,
    title: photo.title || "",
    alt: photo.altText || photo.title || "",
    src: getFallbackUrl(photo.variants),
    srcset: buildSrcset(photo.variants, "webp") || "",
    tags: photo.tags?.map((t) => t.name) || [],
  });
}

const shopBase = lang === "sk" ? `/${lang}/obchod` : `/${lang}/shop`;
const detailBase = `/${lang}/portfolio`;
const hasDogs = dogPhotos.length > 0;
const hasFilm = filmPhotos.length > 0;
---

<!-- Hero -->
<section class="portfolio-hero">
  <h1 class="portfolio-hero__title">{labels.title}</h1>
  <svg class="portfolio-hero__underline" viewBox="0 0 300 12" fill="none" aria-hidden="true">
    <path
      d="M0 6 Q25 0 50 6 Q75 12 100 6 Q125 0 150 6 Q175 12 200 6 Q225 0 250 6 Q275 12 300 6"
      stroke="#FACE68"
      stroke-width="4"
      stroke-linecap="round"
    />
  </svg>
  <p class="portfolio-hero__subtitle">{labels.subtitle}</p>
</section>

{(!hasDogs && !hasFilm) ? (
  <p class="portfolio-empty">{labels.noPhotos}</p>
) : (
  <>
    <!-- Mobile tabs -->
    <div class="portfolio-tabs" role="tablist">
      <button
        class="portfolio-tabs__btn portfolio-tabs__btn--active"
        data-tab-btn="dog"
        role="tab"
        aria-selected="true"
        aria-controls="col-dog"
      >
        {labels.dogSection}
      </button>
      <button
        class="portfolio-tabs__btn"
        data-tab-btn="film"
        role="tab"
        aria-selected="false"
        aria-controls="col-film"
      >
        {labels.filmSection}
      </button>
    </div>

    <!-- Split gallery -->
    <section class="portfolio-split">
      <!-- Dog column -->
      <div class="split-column split-column--dog" id="col-dog" data-column="dog" role="tabpanel">
        <h2 class="split-column__heading">{labels.dogSection}</h2>
        {hasDogs ? (
          <div class="split-column__grid">
            {dogPhotos.map((photo, i) => (
              <button
                class="portfolio-card"
                type="button"
                data-reveal
                data-direction="left"
                data-photo={photoData(photo)}
                style={`--delay: ${(i % 5) * 0.08}s; --rotation: ${rotations[i % rotations.length]}deg`}
              >
                <div class="portfolio-card__frame">
                  <ResponsiveImage
                    variants={photo.variants}
                    alt={photo.altText || photo.title || ""}
                    width={photo.width || 800}
                    height={photo.height || 600}
                    dominantColor={photo.dominantColor}
                    blurhash={photo.blurhash}
                    sizes="(max-width: 768px) 85vw, 40vw"
                  />
                </div>
                <span class="portfolio-card__title">{photo.title}</span>
              </button>
            ))}
          </div>
        ) : (
          <p class="split-column__empty">{labels.noPhotos}</p>
        )}
      </div>

      <!-- Divider -->
      <div class="portfolio-divider" aria-hidden="true">
        <div class="portfolio-divider__line"></div>
      </div>

      <!-- Film column -->
      <div class="split-column split-column--film" id="col-film" data-column="film" role="tabpanel">
        <h2 class="split-column__heading">{labels.filmSection}</h2>
        {hasFilm ? (
          <div class="split-column__grid">
            {filmPhotos.map((photo, i) => (
              <button
                class="portfolio-card"
                type="button"
                data-reveal
                data-direction="right"
                data-photo={photoData(photo)}
                style={`--delay: ${(i % 5) * 0.08}s; --rotation: ${rotations[i % rotations.length]}deg`}
              >
                <div class="portfolio-card__frame">
                  <ResponsiveImage
                    variants={photo.variants}
                    alt={photo.altText || photo.title || ""}
                    width={photo.width || 800}
                    height={photo.height || 600}
                    dominantColor={photo.dominantColor}
                    blurhash={photo.blurhash}
                    sizes="(max-width: 768px) 85vw, 40vw"
                  />
                </div>
                <span class="portfolio-card__title">{photo.title}</span>
              </button>
            ))}
          </div>
        ) : (
          <p class="split-column__empty">{labels.noPhotos}</p>
        )}
      </div>
    </section>

    <!-- Lightbox -->
    <div
      class="lightbox"
      id="portfolio-lightbox"
      role="dialog"
      aria-modal="true"
      aria-label={labels.viewDetail}
      aria-hidden="true"
      data-detail-base={detailBase}
      data-shop-base={shopBase}
    >
      <div class="lightbox__backdrop" data-lightbox-close></div>
      <div class="lightbox__panel">
        <button class="lightbox__close" data-lightbox-close aria-label={labels.close}>
          &times;
        </button>
        <div class="lightbox__frame">
          <img id="lightbox-img" src="" alt="" />
        </div>
        <div class="lightbox__info">
          <h3 id="lightbox-title" class="lightbox__title"></h3>
          <div id="lightbox-tags" class="lightbox__tags"></div>
          <div class="lightbox__actions">
            <a id="lightbox-detail" class="lightbox__btn lightbox__btn--detail" href="#">
              {labels.viewDetail}
            </a>
            <a id="lightbox-shop" class="lightbox__btn lightbox__btn--shop" href="#">
              {labels.buyAsPrint}
            </a>
          </div>
        </div>
      </div>
    </div>
  </>
)}

<style lang="scss">
  @use "sass:color";
  @use "../styles/variables" as *;

  // ── Keyframes ─────────────────────────────────────────
  @keyframes dropIn {
    0% { transform: translateY(-30px); opacity: 0; }
    60% { transform: translateY(4px); opacity: 1; }
    100% { transform: translateY(0); opacity: 1; }
  }

  @keyframes drawLine {
    from { stroke-dashoffset: 320; }
    to { stroke-dashoffset: 0; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  // ── Hero ──────────────────────────────────────────────
  .portfolio-hero {
    text-align: center;
    padding: 3rem 2rem 1.5rem;
  }

  .portfolio-hero__title {
    font-family: $font-heading;
    font-size: 3.5rem;
    color: $dark;
    margin: 0;
    display: inline-block;
    animation: dropIn 0.6s ease forwards;
  }

  .portfolio-hero__underline {
    display: block;
    width: 200px;
    height: 12px;
    margin: -2px auto 0;

    path {
      stroke-dasharray: 320;
      stroke-dashoffset: 320;
      animation: drawLine 1s ease 0.3s forwards;
    }
  }

  .portfolio-hero__subtitle {
    font-family: $font-body;
    font-size: 1.15rem;
    font-weight: 600;
    color: $dark;
    margin-top: 0.75rem;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.7s forwards;
  }

  .portfolio-empty {
    text-align: center;
    font-family: $font-body;
    font-size: 1.1rem;
    color: $dark;
    padding: 4rem 2rem;
  }

  // ── Mobile Tabs ───────────────────────────────────────
  .portfolio-tabs {
    display: none;
  }

  // ── Split Layout ──────────────────────────────────────
  .portfolio-split {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  // ── Column ────────────────────────────────────────────
  .split-column {
    min-width: 0;
  }

  .split-column--dog {
    --accent: #{$yellow};
    background: linear-gradient(135deg, rgba($yellow, 0.04) 0%, transparent 60%);
    border-radius: 12px;
    padding: 0 0.5rem;
  }

  .split-column--film {
    --accent: #{$blue};
    background: linear-gradient(225deg, rgba($blue, 0.04) 0%, transparent 60%);
    border-radius: 12px;
    padding: 0 0.5rem;
  }

  .split-column__heading {
    font-family: $font-heading;
    font-size: 1.6rem;
    color: $dark;
    text-align: center;
    position: sticky;
    top: $nav-height;
    background: rgba($cream, 0.95);
    backdrop-filter: blur(8px);
    padding: 1rem 0;
    margin: 0 0 1.5rem;
    z-index: 10;
    border-radius: 0 0 8px 8px;

    &::after {
      content: "";
      display: block;
      width: 50px;
      height: 4px;
      background: var(--accent);
      margin: 0.5rem auto 0;
      border-radius: 2px;
    }
  }

  .split-column__grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .split-column__empty {
    text-align: center;
    font-family: $font-body;
    color: $dark;
    padding: 3rem 1rem;
    opacity: 0.6;
  }

  // ── Divider ───────────────────────────────────────────
  .portfolio-divider {
    display: flex;
    align-items: stretch;
    justify-content: center;
    padding: 3rem 0;
  }

  .portfolio-divider__line {
    width: 4px;
    border-radius: 2px;
    background: repeating-linear-gradient(
      to bottom,
      $yellow 0,
      $yellow 20px,
      transparent 20px,
      transparent 28px,
      $blue 28px,
      $blue 48px,
      transparent 48px,
      transparent 56px
    );
  }

  // ── Card ──────────────────────────────────────────────
  .portfolio-card {
    // Reset button styles
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    text-align: center;
    cursor: pointer;

    // Reveal animation
    opacity: 0;
    transform: translateX(var(--reveal-x, 0px)) translateY(24px);
    transition:
      opacity 0.6s ease var(--delay, 0s),
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) var(--delay, 0s);

    &.revealed {
      opacity: 1;
      transform: none;
    }

    &[data-direction="left"] {
      --reveal-x: -50px;
    }

    &[data-direction="right"] {
      --reveal-x: 50px;
    }
  }

  .portfolio-card__frame {
    background: #fff;
    padding: 10px;
    border: $outline-width solid $outline;
    border-radius: 4px;
    box-shadow: 3px 3px 0 $outline;
    overflow: hidden;
    transform: rotate(var(--rotation, 0deg));
    transition:
      transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.35s ease,
      border-color 0.35s ease;

    :global(picture) {
      display: block;
    }

    :global(img) {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 2px;
      transition: transform 0.4s ease;
    }
  }

  .portfolio-card__title {
    display: block;
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.95rem;
    color: $dark;
    padding: 0.6rem 0.25rem 0;
    transition: color $transition-fast;
  }

  // Hover — desktop only
  @media (hover: hover) {
    .portfolio-card:hover .portfolio-card__frame,
    .portfolio-card:focus-visible .portfolio-card__frame {
      transform: rotate(0deg) translateY(-6px);
      box-shadow: 6px 8px 0 $outline;
      border-color: var(--accent, $outline);
    }

    .portfolio-card:hover .portfolio-card__frame :global(img),
    .portfolio-card:focus-visible .portfolio-card__frame :global(img) {
      transform: scale(1.05);
    }

    .portfolio-card:hover .portfolio-card__title,
    .portfolio-card:focus-visible .portfolio-card__title {
      color: var(--accent, $dark);
    }
  }

  // Focus outline for keyboard nav
  .portfolio-card:focus-visible {
    outline: 3px solid var(--accent, $blue);
    outline-offset: 4px;
    border-radius: 4px;
  }

  // ── Lightbox ──────────────────────────────────────────
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(6px);
    cursor: pointer;
  }

  .lightbox__panel {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 900px;
    width: 92vw;
    max-height: 90vh;
    overflow-y: auto;
    transform: scale(0.92);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    scrollbar-width: thin;
  }

  .lightbox.is-open .lightbox__panel {
    transform: scale(1);
  }

  .lightbox__close {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: $red;
    border: $outline-width solid $outline;
    color: $white;
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0 $outline;
    z-index: 2;
    transition: transform $transition-fast, background $transition-fast;

    &:hover,
    &:focus-visible {
      transform: scale(1.12);
      background: color.adjust($red, $lightness: -10%);
    }

    &:focus-visible {
      outline: 3px solid $white;
      outline-offset: 2px;
    }
  }

  .lightbox__frame {
    background: #fff;
    padding: 12px;
    border: $outline-width-thick solid $outline;
    border-radius: 4px;
    box-shadow: 4px 4px 0 $outline;
    width: 100%;

    img {
      display: block;
      width: 100%;
      max-height: 65vh;
      object-fit: contain;
      border-radius: 2px;
    }
  }

  .lightbox__info {
    padding: 1.25rem 0.5rem 0.5rem;
    text-align: center;
    width: 100%;
  }

  .lightbox__title {
    font-family: $font-heading;
    font-size: 1.4rem;
    color: $white;
    margin: 0 0 0.75rem;
  }

  .lightbox__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  // Tag pills are injected by JS — use :global
  .lightbox__tags :global(.lightbox__tag) {
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.8rem;
    padding: 0.2rem 0.7rem;
    background: rgba(255, 255, 255, 0.12);
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    color: $white;
  }

  .lightbox__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .lightbox__btn {
    font-family: $font-body;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.55rem 1.4rem;
    border: $outline-width solid $outline;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 2px 2px 0 $outline;
    transition: transform $transition-fast, background $transition-fast;

    &:hover,
    &:focus-visible {
      transform: translateY(-2px);
      box-shadow: 3px 4px 0 $outline;
    }

    &--detail {
      background: $yellow;
      color: $dark;
    }

    &--shop {
      background: $blue;
      color: $white;
    }
  }

  // ── Responsive: Tablet ────────────────────────────────
  @media (max-width: $breakpoint-lg) {
    .portfolio-hero__title {
      font-size: 2.8rem;
    }

    .split-column__heading {
      font-size: 1.35rem;
    }
  }

  // ── Responsive: Mobile ────────────────────────────────
  @media (max-width: $breakpoint-md) {
    .portfolio-hero {
      padding: 2rem 1.25rem 1rem;
    }

    .portfolio-hero__title {
      font-size: 2.2rem;
    }

    .portfolio-hero__underline {
      width: 150px;
    }

    .portfolio-hero__subtitle {
      font-size: 1rem;
    }

    // Show tabs
    .portfolio-tabs {
      display: flex;
      justify-content: center;
      margin: 0 1.25rem 1.5rem;
      border: $outline-width solid $outline;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 2px 2px 0 $outline;
    }

    .portfolio-tabs__btn {
      flex: 1;
      padding: 0.7rem 0.5rem;
      font-family: $font-body;
      font-weight: 700;
      font-size: 0.95rem;
      background: $white;
      border: none;
      cursor: pointer;
      color: $dark;
      transition: background $transition-fast, color $transition-fast;

      &--active {
        background: $dark;
        color: $white;
      }

      &:first-child {
        border-right: $outline-width solid $outline;
      }
    }

    // Stack columns
    .portfolio-split {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0 1.25rem 3rem;
    }

    // Hide divider
    .portfolio-divider {
      display: none;
    }

    // Hide inactive column
    .split-column--hidden {
      display: none;
    }

    .split-column {
      padding: 0;
      background: none;
    }

    .split-column__heading {
      position: static;
      background: none;
      backdrop-filter: none;
      font-size: 1.3rem;
      padding: 0.5rem 0;
      margin-bottom: 1rem;
    }

    .split-column__grid {
      gap: 1.5rem;
    }

    // Cards slide up on mobile, not left/right
    .portfolio-card {
      --reveal-x: 0px !important;
      transform: translateY(30px);
    }

    // Lightbox fullscreen
    .lightbox__panel {
      width: 96vw;
      max-height: 92vh;
    }

    .lightbox__close {
      top: -10px;
      right: -6px;
      width: 36px;
      height: 36px;
      font-size: 1.3rem;
    }

    .lightbox__frame {
      padding: 8px;
    }

    .lightbox__frame img {
      max-height: 55vh;
    }

    .lightbox__title {
      font-size: 1.15rem;
    }

    .lightbox__btn {
      font-size: 0.85rem;
      padding: 0.5rem 1.1rem;
    }
  }

  // ── Reduced Motion ────────────────────────────────────
  @media (prefers-reduced-motion: reduce) {
    .portfolio-hero__title {
      animation: none;
      opacity: 1;
    }

    .portfolio-hero__underline path {
      animation: none;
      stroke-dashoffset: 0;
    }

    .portfolio-hero__subtitle {
      animation: none;
      opacity: 1;
    }

    .portfolio-card {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .portfolio-card__frame {
      transform: none;
    }

    .lightbox,
    .lightbox__panel {
      transition-duration: 0.01ms;
    }
  }
</style>

<script>
  function initPortfolio() {
    // ── Scroll Reveal ─────────────────────────────────
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );

    if (!prefersReduced) {
      document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => observer.observe(el));
    } else {
      document
        .querySelectorAll("[data-reveal]")
        .forEach((el) => el.classList.add("revealed"));
    }

    // ── Lightbox ──────────────────────────────────────
    const lightbox = document.getElementById("portfolio-lightbox");
    if (!lightbox) return;

    const lightboxImg = document.getElementById(
      "lightbox-img"
    ) as HTMLImageElement;
    const lightboxTitle = document.getElementById("lightbox-title")!;
    const lightboxTags = document.getElementById("lightbox-tags")!;
    const lightboxDetail = document.getElementById(
      "lightbox-detail"
    ) as HTMLAnchorElement;
    const lightboxShop = document.getElementById(
      "lightbox-shop"
    ) as HTMLAnchorElement;

    const detailBase = lightbox.dataset.detailBase || "";
    const shopBase = lightbox.dataset.shopBase || "";
    let lastFocus: HTMLElement | null = null;

    function openLightbox(data: {
      slug: string;
      title: string;
      alt: string;
      src: string;
      srcset: string;
      tags: string[];
    }) {
      lightboxImg.src = data.src;
      if (data.srcset) {
        lightboxImg.srcset = data.srcset;
        lightboxImg.sizes = "(max-width: 900px) 88vw, 800px";
      } else {
        lightboxImg.removeAttribute("srcset");
        lightboxImg.removeAttribute("sizes");
      }
      lightboxImg.alt = data.alt;
      lightboxTitle.textContent = data.title;

      // Build tag pills with DOM methods
      lightboxTags.innerHTML = "";
      data.tags.forEach((tagName) => {
        const span = document.createElement("span");
        span.className = "lightbox__tag";
        span.textContent = tagName;
        lightboxTags.appendChild(span);
      });

      lightboxDetail.href = `${detailBase}/${data.slug}`;
      lightboxShop.href = `${shopBase}/${data.slug}`;

      lightbox.setAttribute("aria-hidden", "false");
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";

      // Focus close button
      const closeBtn = lightbox.querySelector<HTMLElement>(
        "[data-lightbox-close]"
      );
      if (closeBtn) closeBtn.focus();
    }

    function closeLightbox() {
      lightbox.classList.remove("is-open");
      lightbox.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      if (lastFocus) lastFocus.focus();
    }

    // Card click handlers
    document
      .querySelectorAll<HTMLElement>("[data-photo]")
      .forEach((card) => {
        card.addEventListener("click", () => {
          lastFocus = card;
          try {
            const data = JSON.parse(card.getAttribute("data-photo") || "{}");
            openLightbox(data);
          } catch {
            // invalid data, ignore
          }
        });
      });

    // Close handlers
    document
      .querySelectorAll("[data-lightbox-close]")
      .forEach((el) => {
        el.addEventListener("click", (e) => {
          // Only close on backdrop click, not panel click
          if (e.target === el) closeLightbox();
        });
      });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lightbox.classList.contains("is-open")) {
        closeLightbox();
      }
    });

    // Focus trap within lightbox
    lightbox.addEventListener("keydown", (e) => {
      if (e.key !== "Tab") return;
      const focusable = lightbox.querySelectorAll<HTMLElement>(
        'button, a[href], [tabindex]:not([tabindex="-1"])'
      );
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    // ── Mobile Tabs ───────────────────────────────────
    const tabBtns = document.querySelectorAll<HTMLElement>("[data-tab-btn]");
    const columns = document.querySelectorAll<HTMLElement>("[data-column]");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = btn.getAttribute("data-tab-btn");

        tabBtns.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle("portfolio-tabs__btn--active", isActive);
          b.setAttribute("aria-selected", String(isActive));
        });

        columns.forEach((col) => {
          const isHidden = col.getAttribute("data-column") !== tab;
          col.classList.toggle("split-column--hidden", isHidden);
        });

        // Re-observe newly visible cards that haven't been revealed
        if (!prefersReduced) {
          document
            .querySelectorAll(
              "[data-column]:not(.split-column--hidden) [data-reveal]:not(.revealed)"
            )
            .forEach((el) => observer.observe(el));
        }
      });
    });
  }

  initPortfolio();
  document.addEventListener("astro:after-swap", initPortfolio);
</script>
