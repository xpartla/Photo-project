---
import { t } from "../lib/i18n";

interface Props { lang: "sk" | "en"; }
const { lang } = Astro.props;
const langSlug = lang === "sk" ? "obchod" : "shop";
---

<div data-admin-root hidden>
  <header class="admin__header">
    <a href={`/${lang}/admin/${langSlug}`} class="admin__back">← {t(lang, "admin.common.backToList")}</a>
    <h1 class="admin__title">{t(lang, "admin.shop.allOrders")}</h1>
  </header>

  <div style="margin-bottom:16px;">
    <label class="account-form__label" for="status-filter" style="display:inline-block;margin-right:8px;">{t(lang, "admin.shop.statusFilter")}</label>
    <select id="status-filter" class="account-form__input" style="display:inline-block;width:auto;">
      <option value="">{t(lang, "admin.shop.allStatuses")}</option>
      <option value="pending_payment">{t(lang, "order.status.pending_payment")}</option>
      <option value="paid">{t(lang, "order.status.paid")}</option>
      <option value="processing">{t(lang, "order.status.processing")}</option>
      <option value="shipped">{t(lang, "order.status.shipped")}</option>
      <option value="completed">{t(lang, "order.status.completed")}</option>
      <option value="cancelled">{t(lang, "order.status.cancelled")}</option>
      <option value="refunded">{t(lang, "order.status.refunded")}</option>
    </select>
  </div>

  <section class="admin-list">
    <ul id="order-list" class="admin-list__items"></ul>
    <p id="order-empty" class="admin-list__empty" hidden>{t(lang, "admin.common.empty")}</p>
  </section>
</div>

<p class="admin__notice" data-admin-denied hidden>{t(lang, "admin.notAuthorized")}</p>

<script id="order-config" type="application/json" set:html={JSON.stringify({
  lang,
  detailPath: `/${lang}/admin/${langSlug}/orders`,
  statusUpdated: t(lang, "admin.shop.statusUpdated"),
  statusLabels: {
    pending_payment: t(lang, "order.status.pending_payment"),
    paid: t(lang, "order.status.paid"),
    processing: t(lang, "order.status.processing"),
    shipped: t(lang, "order.status.shipped"),
    completed: t(lang, "order.status.completed"),
    cancelled: t(lang, "order.status.cancelled"),
    refunded: t(lang, "order.status.refunded"),
  },
})}></script>

<script>
  import { requireAdmin } from "../lib/admin";
  import { adminListOrders } from "../lib/admin-api";

  const cfg = JSON.parse(document.getElementById("order-config")!.textContent!);
  const token = requireAdmin(cfg.lang);
  if (!token) throw new Error("not admin");

  const root = document.querySelector("[data-admin-root]") as HTMLElement;
  root.hidden = false;

  const listEl = document.getElementById("order-list")!;
  const emptyEl = document.getElementById("order-empty")!;
  const filter = document.getElementById("status-filter") as HTMLSelectElement;

  function escapeHtml(s: string): string {
    return (s || "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "\"": "&quot;", "'": "&#39;" }[c]!));
  }
  function statusLabel(s: string): string { return cfg.statusLabels[s] ?? s; }

  async function load() {
    try {
      const orders = await adminListOrders(filter.value || undefined);
      if (orders.length === 0) {
        listEl.innerHTML = "";
        emptyEl.hidden = false;
        return;
      }
      emptyEl.hidden = true;
      listEl.innerHTML = orders.map((o: any) => `
        <li class="admin-list__item">
          <div class="admin-list__main">
            <div>
              <a class="admin-list__title" href="${cfg.detailPath}/${escapeHtml(o.id)}">#${o.id.slice(0, 8)}</a>
              <div class="admin-list__meta">
                <span class="admin-status-pill admin-status-pill--${escapeHtml(o.status)}">${escapeHtml(statusLabel(o.status))}</span>
                <span>${o.totalAmount} ${escapeHtml(o.currency)}</span>
                <span>${new Date(o.createdAt).toLocaleString()}</span>
              </div>
            </div>
          </div>
          <div class="admin-list__actions">
            <a href="${cfg.detailPath}/${escapeHtml(o.id)}" class="admin-list__btn">→</a>
          </div>
        </li>
      `).join("");
    } catch (err: any) {
      listEl.innerHTML = `<li class="admin-list__error">${escapeHtml(err.message)}</li>`;
    }
  }

  filter.addEventListener("change", load);
  load();
</script>
